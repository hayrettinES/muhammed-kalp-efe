@* Herkese açık kurs detay sayfası — EduVerse tasarımı *@
@model KursDetayViewModel
@{
    ViewData["Title"] = Model.KursKart.Kurs.Baslik;
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduVerse</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <script src="~/js/theme.js" asp-append-version="true"></script>
<style>
/* ── TOP NAV ── */
nav {
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1rem 3rem;
  background:rgba(17,24,39,.6);
  backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
}
.nav-logo {
  font-family:'Cormorant Garamond', serif;font-size:1.7rem;font-weight:700;
  color:var(--copper);text-decoration:none;
}
.nav-logo em {font-style:italic;color:var(--text)}
.nav-links {display:flex;list-style:none;gap:2rem;align-items:center;margin:0;}
.nav-links a {
  font-family:'Plus Jakarta Sans', sans-serif;font-size:.8rem;font-weight:600;
  color:var(--text2);text-decoration:none;
  transition:color .2s;
}
.nav-links a:hover {color:var(--text)}
.nav-cta {
  font-family:'Plus Jakarta Sans', sans-serif;font-size:.78rem;font-weight:700;
  padding:.6rem 1.6rem;border-radius:100px;
  background:linear-gradient(135deg,var(--copper),#d4704a);
  color:#fff;text-decoration:none;
}
.theme-toggle-wrap { display:flex; align-items:center; gap:8px; cursor:pointer; }
.theme-toggle-icon { font-size:1rem; }
.theme-toggle-track {
  width:36px;height:20px;border-radius:10px;
  background:rgba(255,255,255,.1);border:1px solid var(--border);
  position:relative;transition:all .3s;
}
.theme-toggle-thumb {
  width:14px;height:14px;border-radius:50%;background:var(--copper);
  position:absolute;top:2px;left:2px;transition:all .3s;
}
html[data-theme="light"] .theme-toggle-track { background:rgba(0,0,0,.1); border-color:rgba(0,0,0,.15); }
html[data-theme="light"] .theme-toggle-thumb { transform:translateX(16px); background:#c47820; }
html[data-theme="light"] nav { background:rgba(255,255,255,.9); }

/* ── OVERRIDES & CORE ── */
:root {
  --fh:'Cormorant Garamond',serif;--fs:'Plus Jakarta Sans',sans-serif;--fm:'JetBrains Mono',monospace;
  --r:12px;--r2:20px;
}
body {
  font-family:var(--fs);background:var(--bg);color:var(--text);
  margin:0;padding-top:80px;
}
*,*::before,*::after{box-sizing:border-box}
.kd-wrap{
  max-width:1240px;margin:0 auto;
  padding:2rem 1.5rem 4rem;
}

/* ── Back link ── */
.kd-back{
  display:inline-flex;align-items:center;gap:.5rem;
  font-family:var(--fm);font-size:.72rem;letter-spacing:.08em;
  color:var(--text2);text-decoration:none;margin-bottom:1.8rem;
  transition:color .2s;
}
.kd-back:hover{color:var(--copper)}

/* ── Hero ── */
.kd-hero{
  display:grid;grid-template-columns:1.3fr .7fr;
  gap:2rem;align-items:start;margin-bottom:2.5rem;
}
@@media(max-width:900px){.kd-hero{grid-template-columns:1fr}}

.kd-left{display:flex;flex-direction:column;gap:1.1rem}
.kd-badge{
  display:inline-block;font-family:var(--fm);font-size:.6rem;
  letter-spacing:.18em;text-transform:uppercase;
  padding:.28rem .85rem;border-radius:100px;
  background:rgba(232,146,74,.18);color:var(--copper);
  align-self:flex-start;
}
.kd-title{
  font-family:var(--fh);font-size:clamp(1.8rem,4vw,3rem);
  font-weight:700;color:var(--text);line-height:1.1;
}
.kd-desc{font-family:var(--fs);font-size:.95rem;color:var(--text2);line-height:1.7}
.kd-meta{
  display:flex;flex-wrap:wrap;gap:1rem;
  font-family:var(--fm);font-size:.65rem;color:var(--muted);
}
.kd-meta span{display:flex;align-items:center;gap:.3rem}

/* ── Info card (right) ── */
.kd-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r2);padding:1.8rem;
  display:flex;flex-direction:column;gap:1rem;
  backdrop-filter:blur(12px);position:sticky;top:1.2rem;
}
.kd-price{
  font-family:var(--fh);font-size:2.4rem;font-weight:700;
  color:var(--copper);line-height:1;
}
.kd-price.free{color:var(--mint)}

/* ── Buttons ── */
.btn-primary{
  display:inline-flex;align-items:center;justify-content:center;
  gap:.5rem;width:100%;padding:.85rem 1.5rem;
  border-radius:100px;border:none;cursor:pointer;
  font-family:var(--fs);font-size:.85rem;font-weight:700;
  background:linear-gradient(135deg,var(--copper),#d4704a);
  color:#fff;text-decoration:none;
  box-shadow:0 4px 20px rgba(232,146,74,.35);
  transition:transform .2s,box-shadow .2s;
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,146,74,.45)}
.btn-glass{
  display:inline-flex;align-items:center;justify-content:center;
  gap:.5rem;width:100%;padding:.75rem 1.5rem;
  border-radius:100px;cursor:pointer;
  font-family:var(--fs);font-size:.82rem;font-weight:600;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.14);
  color:var(--text);text-decoration:none;
  transition:background .2s,border-color .2s;
}
.btn-glass:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.24)}
.badge-owned{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.6rem 1rem;border-radius:100px;
  background:rgba(61,255,192,.12);color:var(--mint);
  font-family:var(--fm);font-size:.7rem;font-weight:700;
  letter-spacing:.08em;justify-content:center;
}

/* ── Progress bar ── */
.progress-wrap{display:flex;flex-direction:column;gap:.4rem}
.progress-label{font-family:var(--fm);font-size:.65rem;color:var(--text2)}
.progress-bar-bg{
  height:6px;border-radius:3px;
  background:rgba(255,255,255,.08);overflow:hidden;
}
.progress-bar-fill{
  height:100%;border-radius:3px;
  background:linear-gradient(90deg,var(--mint),var(--blue));
  transition:width .6s ease;
}

/* ── Alerts ── */
.kd-alert{
  padding:1rem 1.2rem;border-radius:var(--r);
  font-family:var(--fs);font-size:.88rem;font-weight:600;margin:.5rem 0;
}
.kd-alert.success{background:rgba(61,255,192,.1);color:var(--mint);border:1px solid rgba(61,255,192,.2)}
.kd-alert.error{background:rgba(232,100,80,.1);color:#ff6b6b;border:1px solid rgba(232,100,80,.2)}

/* ── Body grid ── */
.kd-body{
  display:grid;grid-template-columns:1.4fr .6fr;
  gap:2rem;align-items:start;margin-bottom:2rem;
}
@@media(max-width:900px){.kd-body{grid-template-columns:1fr}}

/* ── Section card ── */
.kd-section{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--r2);padding:1.8rem;
  backdrop-filter:blur(8px);
}
.kd-section-title{
  font-family:var(--fh);font-size:1.4rem;font-weight:700;
  color:var(--text);margin-bottom:1.2rem;
  display:flex;align-items:center;gap:.6rem;
}
.kd-section-title::before{
  content:'';display:block;width:3px;height:1.2em;
  background:var(--copper);border-radius:2px;
}

/* ── Preview video ── */
.kd-video{
  width:100%;border-radius:var(--r);
  background:#000;max-height:280px;
  border:1px solid var(--border);
}

/* ── Chapter list ── */
.chapter-list{display:flex;flex-direction:column;gap:.6rem}
.chapter-item{
  background:rgba(255,255,255,.03);
  border:1px solid var(--border);border-radius:var(--r);
  padding:1rem 1.2rem;transition:border-color .2s,background .2s;
}
.chapter-item:hover{border-color:rgba(232,146,74,.25);background:rgba(232,146,74,.04)}
.chapter-num{
  font-family:var(--fm);font-size:.6rem;color:var(--copper);
  letter-spacing:.12em;text-transform:uppercase;margin-bottom:.3rem;
}
.chapter-name{
  font-family:var(--fh);font-size:1.05rem;font-weight:700;color:var(--text);
}
.chapter-desc{font-family:var(--fs);font-size:.8rem;color:var(--text2);margin-top:.3rem}

/* Chapter actions */
.chapter-actions{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.8rem}
.btn-sm{
  display:inline-flex;align-items:center;gap:.4rem;
  padding:.45rem .9rem;border-radius:100px;border:none;cursor:pointer;
  font-family:var(--fs);font-size:.72rem;font-weight:700;text-decoration:none;
  transition:all .2s;
}
.btn-sm.mint{background:rgba(61,255,192,.12);color:var(--mint);border:1px solid rgba(61,255,192,.2)}
.btn-sm.mint:hover{background:rgba(61,255,192,.2)}
.btn-sm.copper{background:rgba(232,146,74,.12);color:var(--copper);border:1px solid rgba(232,146,74,.2)}
.btn-sm.copper:hover{background:rgba(232,146,74,.2)}

/* ── Review form ── */
.review-form{display:flex;flex-direction:column;gap:.8rem}
.field-group{display:flex;flex-direction:column;gap:.4rem}
.field-label{font-family:var(--fm);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text2);font-weight:700}
.field-input,.field-select,.field-textarea{
  width:100%;background:rgba(255,255,255,.05);
  border:1px solid var(--border);border-radius:var(--r);
  padding:.7rem .9rem;color:var(--text);
  font-family:var(--fs);font-size:.88rem;
  transition:border-color .2s;outline:none;
}
.field-input:focus,.field-select:focus,.field-textarea:focus{border-color:rgba(232,146,74,.4)}
.field-select option{background:#1a2035}
.field-textarea{resize:vertical;min-height:100px}

/* ── Reviews section ── */
.reviews-list{display:flex;flex-direction:column;gap:1.2rem}
.review-card{
  background:rgba(255,255,255,.03);border:1px solid var(--border);
  border-radius:var(--r);padding:1.2rem;
}
.review-header{display:flex;align-items:center;gap:.7rem;margin-bottom:.6rem}
.review-avatar{
  width:38px;height:38px;border-radius:50%;
  background:linear-gradient(135deg,rgba(232,146,74,.3),rgba(61,255,192,.2));
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
}
.review-author{font-family:var(--fs);font-size:.88rem;font-weight:700;color:var(--text)}
.review-stars{font-size:.8rem;color:var(--copper)}
.review-date{font-family:var(--fm);font-size:.6rem;color:var(--muted)}
.review-text{font-family:var(--fs);font-size:.85rem;color:var(--text2);line-height:1.6}

/* Reply */
.replies{
  margin-top:.8rem;padding-top:.8rem;
  border-top:1px solid var(--border);
  display:flex;flex-direction:column;gap:.6rem;
}
.reply-card{
  padding:.7rem .9rem;border-radius:8px;
  background:rgba(255,255,255,.03);
  border-left:2px solid rgba(232,146,74,.3);
}
.reply-meta{
  display:flex;align-items:center;gap:.5rem;margin-bottom:.3rem;
}
.reply-author{font-family:var(--fs);font-size:.8rem;font-weight:700;color:var(--text)}
.reply-role-badge{
  font-family:var(--fm);font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;
  padding:.15rem .5rem;border-radius:100px;
  background:rgba(126,184,255,.12);color:var(--blue);
}
.reply-text{font-family:var(--fs);font-size:.8rem;color:var(--text2)}
.reply-date{font-family:var(--fm);font-size:.58rem;color:var(--muted)}
.reply-form{margin-top:.7rem;display:flex;flex-direction:column;gap:.5rem}

</style>
</head>
<body>

<nav id="nav">
  <a href="/" class="nav-logo">Edu<em>Verse</em></a>
  <ul class="nav-links">
    <li><a href="#icerik">Kurs İçeriği</a></li>
    <li><a href="#yorumlar">Yorumlar</a></li>
    <li>
      <div class="theme-toggle-wrap" id="topThemeToggle">
        <span class="theme-toggle-icon" id="topThemeIcon">🌙</span>
        <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
      </div>
    </li>
    @if(User.Identity?.IsAuthenticated == true) {
      <li><a href="/Ogrenci/Panel" style="color:var(--copper); font-weight:700;">Panele Git</a></li>
    } else {
      <li><a href="/Hesap/Giris" style="color:var(--copper); font-weight:700;">Giriş Yap</a></li>
      <li><a href="/Hesap/KayitOgrenci" class="nav-cta">Kayıt Ol</a></li>
    }
  </ul>
</nav>

<div class="kd-wrap">

  @* ── Back ── *@
  <a href="/" class="kd-back">← Ana Sayfaya Dön</a>

  @* ── Alerts ── *@
  @if (TempData["Mesaj"] is string mesaj)
  {
      <div class="kd-alert success">✓ @mesaj</div>
  }
  @if (TempData["Hata"] is string hata)
  {
      <div class="kd-alert error">✕ @hata</div>
  }

  @* ── Hero ── *@
  <div class="kd-hero">
    <div class="kd-left">
      <span class="kd-badge">@Model.KursKart.KategoriAdi</span>
      <h1 class="kd-title">@Model.KursKart.Kurs.Baslik</h1>
      <p class="kd-desc">@Model.KursKart.Kurs.Aciklama</p>
      <div class="kd-meta">
        <span>👤 @Model.KursKart.EgitmenAdi</span>
        <span>⭐ @Model.KursKart.OrtalamaPuan.ToString("0.0") / 5</span>
        <span>💬 @Model.KursKart.YorumSayisi yorum</span>
        <span>📚 @Model.KursKart.BolumSayisi bölüm</span>
      </div>

      @if (!string.IsNullOrWhiteSpace(Model.KursKart.Kurs.OnizlemeVideoUrl))
      {
          <div>
              <div style="font-family:var(--fm);font-size:.65rem;color:var(--text2);letter-spacing:.1em;text-transform:uppercase;margin-bottom:.5rem;font-weight:700;">▶ Önizleme</div>
              <video class="kd-video" controls src="@Model.KursKart.Kurs.OnizlemeVideoUrl"></video>
          </div>
      }
    </div>

    @* ── Info Card ── *@
    <div class="kd-card">
      @if (Model.KursKart.Kurs.Fiyat > 0)
      {
          <div class="kd-price">₺@Model.KursKart.Kurs.Fiyat.ToString("N0")</div>
      }
      else
      {
          <div class="kd-price free">Ücretsiz</div>
      }

      @if (Model.IlerlemeOzeti is not null && Model.SahipMi)
      {
          <div class="progress-wrap">
              <div class="progress-label">İlerleme: @Model.IlerlemeOzeti.TamamlanmaYuzdesi%</div>
              <div class="progress-bar-bg">
                  <div class="progress-bar-fill" style="width:@Model.IlerlemeOzeti.TamamlanmaYuzdesi%"></div>
              </div>
              <div style="font-family:var(--fm);font-size:.6rem;color:var(--muted)">
                  Son: @(string.IsNullOrWhiteSpace(Model.IlerlemeOzeti.SonKalinanBolumBasligi) ? "Henüz başlanmadı" : Model.IlerlemeOzeti.SonKalinanBolumBasligi)
              </div>
          </div>
      }

      @if (User.Identity?.IsAuthenticated != true)
      {
          <a class="btn-primary" asp-controller="Hesap" asp-action="Giris">🔑 Giriş Yapıp Satın Al</a>
      }
      else if (User.IsInRole("Ogrenci"))
      {
          @if (Model.SahipMi)
          {
              <div class="badge-owned">✓ Bu kurs sende var</div>
          }
          else
          {
              <form asp-controller="Ogrenci" asp-action="KursAl" method="post">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="kursId" value="@Model.KursKart.Kurs.Id" />
                  <button type="submit" class="btn-primary">🛒 Kursu Satın Al</button>
              </form>
          }
      }

      @if (!string.IsNullOrWhiteSpace(Model.KursKart.Kurs.DokumanUrl))
      {
          <a class="btn-glass" href="@Model.KursKart.Kurs.DokumanUrl" target="_blank">📄 Genel Doküman</a>
      }
    </div>
  </div>

  @* ── Body ── *@
  <div class="kd-body">
    @* ── Chapters ── *@
    <div class="kd-section" id="icerik">
      <div class="kd-section-title">Kurs İçeriği</div>

      @if (!Model.SahipMi)
      {
          <p style="font-family:var(--fs);font-size:.88rem;color:var(--text2);line-height:1.6;margin-bottom:1rem;">
            Bu kursun tam içeriği satın alma sonrasında açılır. Şu an önizleme gösterilmektedir.
          </p>
          <p style="font-family:var(--fm);font-size:.72rem;color:var(--muted);">Bölüm başlıkları ve tam videolar satın alma sonrasında açılacak.</p>
      }
      else if (Model.Bolumler.Count == 0)
      {
          <p style="font-family:var(--fs);font-size:.88rem;color:var(--text2);">Bu kursa henüz bölüm eklenmedi.</p>
      }
      else
      {
          <div class="chapter-list">
            @foreach (var bolum in Model.Bolumler)
            {
                <div class="chapter-item">
                    <div class="chapter-num">Bölüm @bolum.SiraNo</div>
                    <div class="chapter-name">@bolum.Baslik</div>
                    @if (!string.IsNullOrWhiteSpace(bolum.Aciklama))
                    {
                        <div class="chapter-desc">@bolum.Aciklama</div>
                    }

                    @if (Model.SahipMi)
                    {
                        <video class="kd-video" controls src="@bolum.VideoUrl" style="margin-top:.8rem;"></video>
                        <div class="chapter-actions">
                            <form asp-controller="Ogrenci" asp-action="BolumDurumuKaydet" method="post" style="display:contents">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="kursId" value="@Model.KursKart.Kurs.Id" />
                                <input type="hidden" name="kursBolumuId" value="@bolum.Id" />
                                <input type="hidden" name="tamamlandiMi" value="false" />
                                <button type="submit" class="btn-sm mint">📍 Son Kalınan Yer Kaydet</button>
                            </form>
                            <form asp-controller="Ogrenci" asp-action="BolumDurumuKaydet" method="post" style="display:contents">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="kursId" value="@Model.KursKart.Kurs.Id" />
                                <input type="hidden" name="kursBolumuId" value="@bolum.Id" />
                                <input type="hidden" name="tamamlandiMi" value="true" />
                                <button type="submit" class="btn-sm copper">✓ Tamamlandı Olarak İşaretle</button>
                            </form>
                            @if (!string.IsNullOrWhiteSpace(bolum.DokumanUrl))
                            {
                                <a class="btn-sm mint" href="@bolum.DokumanUrl" target="_blank">📄 Doküman</a>
                            }
                        </div>
                    }
                </div>
            }
          </div>
      }
    </div>

    @* ── Review Form ── *@
    <div class="kd-section">
      <div class="kd-section-title">Puan & Yorum</div>
      @if (Model.YorumYapabilirMi)
      {
          <form asp-controller="Ogrenci" asp-action="YorumYap" method="post" class="review-form">
              @Html.AntiForgeryToken()
              <input type="hidden" name="kursId" value="@Model.KursKart.Kurs.Id" />
              <div class="field-group">
                  <label class="field-label">Puan</label>
                  <select class="field-select" name="puan" required>
                      <option value="5">⭐⭐⭐⭐⭐ Mükemmel</option>
                      <option value="4">⭐⭐⭐⭐ Çok İyi</option>
                      <option value="3">⭐⭐⭐ İyi</option>
                      <option value="2">⭐⭐ Orta</option>
                      <option value="1">⭐ Kötü</option>
                  </select>
              </div>
              <div class="field-group">
                  <label class="field-label">Yorumunuz</label>
                  <textarea class="field-textarea" name="yorum" rows="4" required placeholder="Kurs hakkındaki düşüncelerinizi paylaşın..."></textarea>
              </div>
              <button type="submit" class="btn-primary">💬 Yorum Gönder</button>
          </form>
      }
      else
      {
          <p style="font-family:var(--fs);font-size:.88rem;color:var(--text2);line-height:1.6;">
            Yorum yapmak için kursu satın alıp öğrenci olarak oturum açmanız gerekir.
          </p>
      }
    </div>
  </div>

  @* ── Reviews ── *@
  <div class="kd-section" id="yorumlar">
    <div class="kd-section-title">Yorumlar & Yanıtlar</div>
    @if (Model.Yorumlar.Count == 0)
    {
        <p style="font-family:var(--fs);font-size:.88rem;color:var(--text2);">Bu kursa henüz yorum gelmedi.</p>
    }
    else
    {
        <div class="reviews-list">
          @foreach (var yorum in Model.Yorumlar)
          {
              <div class="review-card">
                  <div class="review-header">
                      <div class="review-avatar">👤</div>
                      <div>
                          <div class="review-author">@yorum.OgrenciAdi</div>
                          <div style="display:flex;align-items:center;gap:.5rem">
                              <span class="review-stars">@string.Concat(Enumerable.Repeat("★", yorum.Puan))@string.Concat(Enumerable.Repeat("☆", 5 - yorum.Puan))</span>
                              <span class="review-date">@yorum.Tarih</span>
                          </div>
                      </div>
                  </div>
                  <p class="review-text">@yorum.Yorum</p>

                  @if (yorum.Yanitlar.Count > 0)
                  {
                      <div class="replies">
                          @foreach (var yanit in yorum.Yanitlar)
                          {
                              <div class="reply-card">
                                  <div class="reply-meta">
                                      <span class="reply-author">@yanit.KullaniciAdi</span>
                                      <span class="reply-role-badge">@yanit.KullaniciRol</span>
                                      <span class="reply-date">@yanit.Tarih</span>
                                  </div>
                                  <p class="reply-text">@yanit.Yanit</p>
                              </div>
                          }
                      </div>
                  }

                  @if (User.Identity?.IsAuthenticated == true)
                  {
                      <form asp-controller="Yorum" asp-action="YanitEkle" method="post" class="reply-form">
                          @Html.AntiForgeryToken()
                          <input type="hidden" name="kursId" value="@Model.KursKart.Kurs.Id" />
                          <input type="hidden" name="kursYorumuId" value="@yorum.Id" />
                          <textarea class="field-textarea" name="yanit" rows="2" required placeholder="Yanıtınızı yazın..." style="min-height:64px"></textarea>
                          <button type="submit" class="btn-sm copper" style="align-self:flex-start">↩ Yanıt Gönder</button>
                      </form>
                  }
              </div>
          }
        </div>
    }
  </div>

</div>

<script>
    const themeToggle = document.getElementById('topThemeToggle');
    const themeIcon = document.getElementById('topThemeIcon');

    function syncUI() {
        const isLight = document.documentElement.getAttribute('data-theme') === 'light';
        if (themeIcon) themeIcon.textContent = isLight ? '☀️' : '🌙';
    }
    syncUI();

    if (themeToggle) {
        themeToggle.addEventListener('click', () => {
            const isLight = document.documentElement.getAttribute('data-theme') === 'light';
            const next = isLight ? 'dark' : 'light';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            syncUI();
        });
    }
</script>
</body>
</html>
