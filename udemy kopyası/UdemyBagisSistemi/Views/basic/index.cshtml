@{
    Layout = null;
}
@model UdemyBagisSistemi.ViewModels.AnasayfaViewModel
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EduVerse — Geleceği Birlikte İnşa Et</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
  <script src="~/js/theme.js" asp-append-version="true"></script>
  <style>
    /* ╔══════════════════════════════════════════╗
       ║  TOKENS & RESET                          ║
       ╚══════════════════════════════════════════╝ */
    :root{
      --bg:        #141c2e;
      --bg2:       #111827;
      --surface:   rgba(255,255,255,.05);
      --surfaceH:  rgba(255,255,255,.09);
      --glass:     rgba(20,28,46,.7);
      --border:    rgba(255,255,255,.09);
      --borderH:   rgba(255,255,255,.18);
      --copper:    #e8924a;
      --mint:      #3dffc0;
      --blue:      #7eb8ff;
      --lavender:  #b89cff;
      --text:      #e2e8f4;
      --text2:     #8898b8;
      --muted:     #4a5878;
      --fh:        'Cormorant Garamond', serif;
      --fs:        'Plus Jakarta Sans', sans-serif;
      --fm:        'JetBrains Mono', monospace;
      --r:         12px;
      --r2:        20px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      background:var(--bg);color:var(--text);
      font-family:var(--fs);overflow-x:hidden;
      -webkit-font-smoothing:antialiased;
    }
    ::-webkit-scrollbar{width:5px}
    ::-webkit-scrollbar-track{background:var(--bg2)}
    ::-webkit-scrollbar-thumb{background:var(--copper);border-radius:3px}

    /* ── CURSOR ─────────────────────────────── */
    #cur{
      position:fixed;width:12px;height:12px;
      border-radius:50%;background:var(--copper);
      pointer-events:none;z-index:9999;
      transform:translate(-50%,-50%);
      transition:width .2s,height .2s,background .2s,opacity .2s;
      mix-blend-mode:screen;
    }
    #cur.big{width:44px;height:44px;opacity:.4}

    /* ── NAV ─────────────────────────────────── */
    nav{
      position:fixed;top:0;left:0;right:0;z-index:100;
      display:flex;align-items:center;justify-content:space-between;
      padding:1.4rem 3rem;
      background:rgba(17,24,39,.6);
      backdrop-filter:blur(24px);
      border-bottom:1px solid var(--border);
      transition:padding .3s, background .3s;
    }
    html[data-theme="light"] nav {
      background: rgba(240, 235, 224, .8);
    }
    nav.shrunk{padding:1rem 3rem}
    .nav-logo{
      font-family:var(--fh);font-size:1.7rem;font-weight:700;
      color:var(--copper);letter-spacing:.01em;
      text-decoration:none;
    }
    .nav-logo em{font-style:italic;color:var(--text)}
    .nav-links{display:flex;list-style:none;gap:2.2rem}
    .nav-links a{
      font-family:var(--fs);font-size:.8rem;font-weight:500;
      color:var(--text2);text-decoration:none;letter-spacing:.04em;
      transition:color .2s;
    }
    .nav-links a:hover{color:var(--text)}
    .nav-cta{
      font-family:var(--fs);font-size:.78rem;font-weight:700;
      padding:.6rem 1.6rem;border-radius:100px;
      background:linear-gradient(135deg,var(--copper),#d4704a);
      color:#fff;text-decoration:none;
      box-shadow:0 4px 20px rgba(232,146,74,.35);
      transition:transform .2s,box-shadow .2s;
    }
    .nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(232,146,74,.45)}

    /* ╔══════════════════════════════════════════╗
       ║  HERO                                    ║
       ╚══════════════════════════════════════════╝ */
    #hero{
      min-height:100vh;position:relative;overflow:hidden;
      display:flex;flex-direction:column;justify-content:center;
      padding:7rem 3rem 5rem;
    }

    /* animated gradient blobs */
    .blob{
      position:absolute;border-radius:50%;filter:blur(100px);
      pointer-events:none;opacity:.5;
    }
    .blob-1{
      width:700px;height:700px;
      background:radial-gradient(circle,rgba(232,146,74,.25),transparent 70%);
      top:-200px;right:-150px;
      animation:blobFloat1 14s ease-in-out infinite alternate;
    }
    .blob-2{
      width:600px;height:600px;
      background:radial-gradient(circle,rgba(61,255,192,.15),transparent 70%);
      bottom:-150px;left:-100px;
      animation:blobFloat2 18s ease-in-out infinite alternate;
    }
    .blob-3{
      width:400px;height:400px;
      background:radial-gradient(circle,rgba(126,184,255,.12),transparent 70%);
      top:30%;left:40%;
      animation:blobFloat3 11s ease-in-out infinite alternate;
    }
    @@keyframes blobFloat1{from{transform:translate(0,0) scale(1)}to{transform:translate(-60px,40px) scale(1.15)}}
    @@keyframes blobFloat2{from{transform:translate(0,0) scale(1)}to{transform:translate(50px,-30px) scale(1.08)}}
    @@keyframes blobFloat3{from{transform:translate(0,0) scale(1)}to{transform:translate(-30px,60px) scale(.9)}}

    /* dot grid overlay */
    #hero::before{
      content:'';position:absolute;inset:0;
      background-image:radial-gradient(circle,rgba(255,255,255,.035) 1px,transparent 1px);
      background-size:36px 36px;pointer-events:none;
    }

    .hero-inner{
      max-width:1280px;margin:0 auto;width:100%;
      display:grid;grid-template-columns:1.1fr .9fr;
      gap:5rem;align-items:center;
      position:relative;z-index:1;
    }

    .hero-left{display:flex;flex-direction:column;gap:1.8rem}
    .hero-eyebrow{
      display:inline-flex;align-items:center;gap:.7rem;
      font-family:var(--fm);font-size:.65rem;letter-spacing:.22em;
      text-transform:uppercase;color:var(--copper);
    }
    .hero-eyebrow::before{
      content:'';display:inline-block;width:28px;height:1px;
      background:var(--copper);
    }
    .hero-title{
      font-family:var(--fh);
      font-size:clamp(4rem,8vw,8rem);
      font-weight:700;line-height:.9;
      letter-spacing:-.02em;
      color:var(--text);
    }
    .hero-title em{
      font-style:italic;
      background:linear-gradient(135deg,var(--copper) 30%,var(--lavender));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
      background-clip:text;
    }
    .hero-subtitle{
      font-family:var(--fs);font-size:1rem;
      color:var(--text2);line-height:1.8;max-width:440px;
      font-weight:400;
    }
    .hero-actions{display:flex;gap:1rem;flex-wrap:wrap;align-items:center}
    .btn-copper{
      font-family:var(--fs);font-size:.82rem;font-weight:700;
      padding:.9rem 2rem;border-radius:100px;
      background:linear-gradient(135deg,var(--copper),#c8703a);
      color:#fff;text-decoration:none;border:none;cursor:pointer;
      box-shadow:0 4px 24px rgba(232,146,74,.4);
      transition:transform .2s,box-shadow .2s;
    }
    .btn-copper:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(232,146,74,.5)}
    .btn-glass{
      font-family:var(--fs);font-size:.82rem;font-weight:600;
      padding:.9rem 2rem;border-radius:100px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.14);
      color:var(--text);text-decoration:none;cursor:pointer;
      backdrop-filter:blur(12px);
      transition:background .2s,border-color .2s;
    }
    .btn-glass:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.24)}

    .hero-trust{
      display:flex;align-items:center;gap:1rem;
      font-family:var(--fm);font-size:.65rem;color:var(--text2);
    }
    .trust-avatars{display:flex}
    .trust-av{
      width:34px;height:34px;border-radius:50%;
      background:linear-gradient(135deg,var(--surface),var(--surfaceH));
      border:2px solid rgba(255,255,255,.12);
      display:flex;align-items:center;justify-content:center;
      font-size:1rem;margin-left:-10px;
    }
    .trust-av:first-child{margin-left:0}

    /* 3D CARD DECK */
    .hero-right{
      display:flex;flex-direction:column;align-items:center;
      gap:2rem;position:relative;
    }
    .deck-scene{
      perspective:1000px;width:340px;height:400px;
      position:relative;
    }
    .deck-card{
      position:absolute;width:280px;
      border-radius:var(--r2);
      backdrop-filter:blur(20px);
      padding:2rem;
      border:1px solid var(--border);
      display:flex;flex-direction:column;gap:1rem;
      transition:transform .6s cubic-bezier(.34,1.56,.64,1),opacity .4s;
    }
    .deck-card:nth-child(1){
      background:linear-gradient(145deg,rgba(232,146,74,.15),var(--glass));
      border-color:rgba(232,146,74,.3);
      transform:translateX(30px) translateY(0px) rotateY(-12deg) rotateX(5deg);
      left:60px;top:0;z-index:3;
      box-shadow:0 30px 80px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.1);
    }
    .deck-card:nth-child(2){
      background:linear-gradient(145deg,rgba(61,255,192,.1),var(--glass));
      border-color:rgba(61,255,192,.25);
      transform:translateX(0px) translateY(40px) rotateY(4deg) rotateX(5deg);
      left:20px;top:40px;z-index:2;
      box-shadow:0 20px 60px rgba(0,0,0,.35);
      filter:brightness(.85);
    }
    .deck-card:nth-child(3){
      background:linear-gradient(145deg,rgba(126,184,255,.1),var(--glass));
      border-color:rgba(126,184,255,.2);
      transform:translateX(-30px) translateY(80px) rotateY(16deg) rotateX(5deg);
      left:0px;top:80px;z-index:1;
      box-shadow:0 10px 40px rgba(0,0,0,.3);
      filter:brightness(.7);
    }
    .dc-icon{font-size:2.2rem}
    .dc-badge{
      font-family:var(--fm);font-size:.6rem;letter-spacing:.18em;
      text-transform:uppercase;
      padding:.25rem .8rem;border-radius:100px;
      display:inline-block;align-self:flex-start;
    }
    .dc-badge-copper{background:rgba(232,146,74,.2);color:var(--copper)}
    .dc-badge-mint  {background:rgba(61,255,192,.15);color:var(--mint)}
    .dc-badge-blue  {background:rgba(126,184,255,.15);color:var(--blue)}
    .dc-title{
      font-family:var(--fh);font-size:1.6rem;font-weight:700;
      color:var(--text);line-height:1;
    }
    .dc-desc{font-family:var(--fs);font-size:.78rem;color:var(--text2);line-height:1.6}
    .dc-stat{
      display:flex;align-items:center;justify-content:space-between;
      border-top:1px solid var(--border);padding-top:.8rem;
    }
    .dc-stat-num{font-family:var(--fh);font-size:1.5rem;font-weight:700;color:var(--copper)}
    .dc-stat-label{font-family:var(--fm);font-size:.58rem;color:var(--text2)}
    .deck-hint{
      font-family:var(--fm);font-size:.6rem;letter-spacing:.15em;
      text-transform:uppercase;color:var(--muted);
      text-align:center;
    }

    /* ── SCROLL PULSE ── */
    .scroll-pulse{
      position:absolute;bottom:2.5rem;left:50%;transform:translateX(-50%);
      display:flex;flex-direction:column;align-items:center;gap:.5rem;
      color:var(--muted);font-family:var(--fm);font-size:.58rem;
      letter-spacing:.15em;text-transform:uppercase;z-index:1;
    }
    .scroll-dot{
      width:6px;height:28px;border-radius:3px;
      border:1px solid var(--muted);position:relative;overflow:hidden;
    }
    .scroll-dot::after{
      content:'';position:absolute;top:0;left:0;right:0;
      height:40%;background:var(--copper);border-radius:3px;
      animation:scrollBounce 1.6s ease-in-out infinite;
    }
    @@keyframes scrollBounce{0%{top:0;opacity:1}100%{top:60%;opacity:0}}

    /* ╔══════════════════════════════════════════╗
       ║  STATS                                   ║
       ╚══════════════════════════════════════════╝ */
    #stats{
      background:rgba(255,255,255,.025);
      border-top:1px solid var(--border);
      border-bottom:1px solid var(--border);
      display:grid;grid-template-columns:repeat(4,1fr);
    }
    .stat{
      padding:2.8rem 2rem;text-align:center;
      border-right:1px solid var(--border);
      display:flex;flex-direction:column;gap:.5rem;
    }
    .stat:last-child{border-right:none}
    .stat-num{
      font-family:var(--fh);font-size:3rem;font-weight:700;
      line-height:1;
      background:linear-gradient(135deg,var(--copper),var(--lavender));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
      background-clip:text;
    }
    .stat-label{
      font-family:var(--fm);font-size:.6rem;letter-spacing:.18em;
      text-transform:uppercase;color:var(--text2);
    }

    /* ╔══════════════════════════════════════════╗
       ║  MARQUEE                                 ║
       ╚══════════════════════════════════════════╝ */
    .marquee-wrap{
      overflow:hidden;padding:1rem 0;
      border-bottom:1px solid var(--border);
      background:linear-gradient(90deg,rgba(232,146,74,.08),rgba(61,255,192,.06),rgba(126,184,255,.08));
    }
    .marquee-track{
      display:flex;white-space:nowrap;
      animation:marquee 40s linear infinite;
    }
    .marquee-item{
      font-family:var(--fh);font-size:1.65rem;font-weight:600;
      font-style:italic;color:var(--text2);padding:0 5rem;
      display:inline-flex;align-items:center;gap:2.5rem;
    }
    .marquee-gem{font-style:normal;font-size:.75rem;color:var(--copper)}
    @@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    /* ╔══════════════════════════════════════════╗
       ║  COURSES                                 ║
       ╚══════════════════════════════════════════╝ */
    .donor-marquee {
      background:linear-gradient(90deg,rgba(61,255,192,.1),rgba(126,184,255,.1));
      border-bottom:1px solid var(--border);
      border-top:1px solid var(--border);
      margin-top: 1.5rem;
    }
    .donor-marquee .marquee-item {
      font-size: 1.65rem;
      color: var(--mint);
      font-weight: 700;
    }
    #courses{padding:8rem 3rem;max-width:1320px;margin:0 auto}
    .section-top{
      display:flex;align-items:flex-end;justify-content:space-between;
      margin-bottom:4rem;flex-wrap:wrap;gap:2rem;
    }
    .eyebrow{
      font-family:var(--fm);font-size:.62rem;letter-spacing:.22em;
      text-transform:uppercase;color:var(--copper);
      display:flex;align-items:center;gap:.6rem;margin-bottom:.8rem;
    }
    .eyebrow::before{content:'';display:inline-block;width:20px;height:1px;background:var(--copper)}
    .section-title{
      font-family:var(--fh);
      font-size:clamp(2.5rem,5vw,4.5rem);
      font-weight:700;line-height:1;color:var(--text);
    }
    .section-title em{font-style:italic;color:var(--copper)}
    .filters{display:flex;gap:.5rem;flex-wrap:wrap}
    .filter{
      font-family:var(--fm);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;
      padding:.4rem 1.1rem;border-radius:100px;
      border:1px solid var(--border);
      background:transparent;color:var(--text2);cursor:pointer;
      transition:all .2s;
    }
    .filter:hover,.filter.active{
      border-color:var(--copper);color:var(--copper);
      background:rgba(232,146,74,.08);
    }

    /* grid */
    .courses-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
      gap:1.5rem;
    }
    .course-card{
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r2);
      padding:1.8rem;
      display:flex;flex-direction:column;gap:.8rem;
      position:relative;overflow:hidden;
      backdrop-filter:blur(8px);
      transition:background .3s,border-color .3s,transform .3s,box-shadow .3s;
    }
    .course-card::before{
      content:'';position:absolute;inset:0;
      background:radial-gradient(ellipse 80% 50% at 50% -20%,rgba(232,146,74,.08),transparent);
      opacity:0;transition:opacity .3s;pointer-events:none;
    }
    .course-card:hover{
      background:var(--surfaceH);
      border-color:rgba(232,146,74,.3);
      transform:translateY(-4px);
      box-shadow:0 20px 60px rgba(0,0,0,.35),0 0 0 1px rgba(232,146,74,.1);
    }
    .course-card:hover::before{opacity:1}

    .card-top{display:flex;align-items:center;justify-content:space-between}
    .card-badge{
      font-family:var(--fm);font-size:.55rem;letter-spacing:.15em;
      text-transform:uppercase;padding:.22rem .75rem;border-radius:100px;
    }
    .b-copper{background:rgba(232,146,74,.18);color:var(--copper)}
    .b-mint  {background:rgba(61,255,192,.12);color:var(--mint)}
    .b-blue  {background:rgba(126,184,255,.12);color:var(--blue)}
    .b-lav   {background:rgba(184,156,255,.12);color:var(--lavender)}
    .card-num{
      font-family:var(--fh);font-size:3rem;font-weight:700;
      color:rgba(255,255,255,.04);line-height:1;user-select:none;
    }
    .card-title{
      font-family:var(--fh);font-size:1.2rem;font-weight:700;
      color:var(--text);line-height:1.3;
    }
    .card-instructor{
      font-family:var(--fm);font-size:.62rem;color:var(--text2);
    }
    .card-stars{
      display:flex;align-items:center;gap:.5rem;
      font-size:.8rem;color:var(--copper);
    }
    .card-stars span{
      font-family:var(--fm);font-size:.6rem;color:var(--text2);
    }
    .card-meta{
      display:flex;gap:1rem;font-family:var(--fm);
      font-size:.6rem;color:var(--muted);
    }
    .card-footer{
      display:flex;align-items:center;justify-content:space-between;
      border-top:1px solid var(--border);padding-top:1rem;margin-top:auto;
    }
    .card-price-wrap{display:flex;flex-direction:column;gap:.1rem}
    .card-old{
      font-family:var(--fm);font-size:.6rem;
      color:var(--muted);text-decoration:line-through;
    }
    .card-price{
      font-family:var(--fh);font-size:1.7rem;font-weight:700;
      color:var(--copper);line-height:1;
    }
    .card-free{
      font-family:var(--fh);font-size:1.7rem;font-weight:700;
      color:var(--mint);line-height:1;
    }
    .card-enroll{
      font-family:var(--fs);font-size:.72rem;font-weight:700;
      padding:.5rem 1.1rem;border-radius:100px;
      background:rgba(232,146,74,.12);
      border:1px solid rgba(232,146,74,.25);
      color:var(--copper);cursor:pointer;
      transition:all .2s;
    }
    .card-enroll:hover{background:var(--copper);color:#fff;border-color:var(--copper)}

    /* ╔══════════════════════════════════════════╗
       ║  ROLES                                   ║
       ╚══════════════════════════════════════════╝ */
    #roles{position:relative;overflow:hidden;padding:8rem 0}
    .roles-bg{
      position:absolute;inset:0;
      background:
        linear-gradient(180deg,transparent,rgba(232,146,74,.04) 50%,transparent),
        radial-gradient(ellipse 60% 70% at 15% 50%,rgba(232,146,74,.07),transparent),
        radial-gradient(ellipse 40% 70% at 85% 50%,rgba(61,255,192,.05),transparent);
    }
    /* angled top */
    #roles::before{
      content:'';display:block;position:absolute;top:-1px;left:0;right:0;
      height:60px;
      background:var(--bg);
      clip-path:polygon(0 0,100% 0,100% 30%,0 100%);
      z-index:1;
    }
    .roles-inner{
      max-width:1320px;margin:0 auto;padding:0 3rem;
      position:relative;z-index:2;
    }
    .roles-grid{
      display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
      gap:1.5rem;margin-top:4rem;
    }
    .role-card{
      border-radius:var(--r2);padding:2.5rem 2rem;
      display:flex;flex-direction:column;gap:1.2rem;
      position:relative;overflow:hidden;
      border:1px solid var(--border);
      backdrop-filter:blur(12px);
      transition:transform .3s,box-shadow .3s,border-color .3s;
    }
    .role-card:hover{transform:translateY(-6px)}
    .role-card-1{
      background:linear-gradient(145deg,rgba(232,146,74,.12),var(--glass));
    }
    .role-card-1:hover{border-color:rgba(232,146,74,.4);box-shadow:0 24px 80px rgba(232,146,74,.15)}
    .role-card-2{
      background:linear-gradient(145deg,rgba(61,255,192,.08),var(--glass));
    }
    .role-card-2:hover{border-color:rgba(61,255,192,.3);box-shadow:0 24px 80px rgba(61,255,192,.1)}
    .role-card-3{
      background:linear-gradient(145deg,rgba(126,184,255,.08),var(--glass));
    }
    .role-card-3:hover{border-color:rgba(126,184,255,.3);box-shadow:0 24px 80px rgba(126,184,255,.1)}

    .role-num{
      font-family:var(--fh);font-size:5rem;font-weight:700;
      color:rgba(255,255,255,.04);line-height:1;
      position:absolute;top:1rem;right:1.5rem;
      user-select:none;
    }
    .role-icon-wrap{
      width:56px;height:56px;border-radius:14px;
      display:flex;align-items:center;justify-content:center;
      font-size:1.7rem;
    }
    .ri-copper{background:rgba(232,146,74,.15)}
    .ri-mint  {background:rgba(61,255,192,.12)}
    .ri-blue  {background:rgba(126,184,255,.12)}
    .role-title{
      font-family:var(--fh);font-size:2rem;font-weight:700;color:var(--text);
    }
    .role-desc{
      font-family:var(--fs);font-size:.85rem;color:var(--text2);
      line-height:1.7;
    }
    .role-perks{list-style:none;display:flex;flex-direction:column;gap:.6rem}
    .role-perks li{
      display:flex;align-items:center;gap:.6rem;
      font-family:var(--fm);font-size:.65rem;color:var(--text2);
    }
    .rp-dot{
      width:6px;height:6px;border-radius:50%;flex-shrink:0;
    }
    .role-link{
      display:inline-flex;align-items:center;gap:.5rem;
      font-family:var(--fs);font-size:.8rem;font-weight:700;
      text-decoration:none;margin-top:.5rem;
      transition:gap .2s;
    }
    .role-link-copper{color:var(--copper)}
    .role-link-mint  {color:var(--mint)}
    .role-link-blue  {color:var(--blue)}
    .role-link:hover{gap:.9rem}

    /* ╔══════════════════════════════════════════╗
       ║  TESTIMONIALS                            ║
       ╚══════════════════════════════════════════╝ */
    #testi{padding:6rem 3rem;max-width:1320px;margin:0 auto}
    .testi-grid{
      display:grid;grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
      gap:1.5rem;margin-top:4rem;
    }
    .testi-card{
      background:var(--surface);border:1px solid var(--border);
      border-radius:var(--r2);padding:2rem;
      display:flex;flex-direction:column;gap:1.2rem;
      backdrop-filter:blur(8px);
    }
    .testi-quote{
      font-family:var(--fh);font-style:italic;
      font-size:1.1rem;color:var(--text);line-height:1.6;
    }
    .testi-stars{font-size:.9rem;color:var(--copper)}
    .testi-person{
      display:flex;align-items:center;gap:.8rem;
      border-top:1px solid var(--border);padding-top:1rem;
    }
    .testi-av{
      width:40px;height:40px;border-radius:50%;
      background:linear-gradient(135deg,var(--surface),var(--surfaceH));
      border:1.5px solid var(--border);
      display:flex;align-items:center;justify-content:center;font-size:1.2rem;
    }
    .testi-name{
      font-family:var(--fs);font-size:.85rem;font-weight:600;color:var(--text);
    }
    .testi-role{
      font-family:var(--fm);font-size:.58rem;letter-spacing:.08em;color:var(--text2);
    }

    /* ╔══════════════════════════════════════════╗
       ║  CTA BAND                                ║
       ╚══════════════════════════════════════════╝ */
    #cta{
      margin:0 3rem 6rem;border-radius:var(--r2);
      background:linear-gradient(135deg,rgba(232,146,74,.15),rgba(61,255,192,.06),rgba(126,184,255,.08));
      border:1px solid rgba(255,255,255,.1);
      padding:5rem 4rem;
      text-align:center;
      position:relative;overflow:hidden;
    }
    #cta::before{
      content:'';position:absolute;inset:0;
      background:radial-gradient(ellipse 60% 80% at 50% 0%,rgba(232,146,74,.12),transparent);
      pointer-events:none;
    }
    .cta-title{
      font-family:var(--fh);font-size:clamp(2.5rem,5vw,4rem);
      font-weight:700;color:var(--text);
      line-height:1.1;margin-bottom:1.2rem;
    }
    .cta-title em{font-style:italic;color:var(--copper)}
    .cta-sub{
      font-family:var(--fs);font-size:1rem;color:var(--text2);
      max-width:480px;margin:0 auto 2.5rem;line-height:1.7;
    }
    .cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}

    /* ╔══════════════════════════════════════════╗
       ║  FOOTER                                  ║
       ╚══════════════════════════════════════════╝ */
    footer{
      border-top:1px solid var(--border);
      padding:2.5rem 3rem;
      display:flex;align-items:center;justify-content:space-between;
      flex-wrap:wrap;gap:1.2rem;
      background:rgba(0,0,0,.2);
    }
    .footer-logo{
      font-family:var(--fh);font-size:1.5rem;font-weight:700;
      color:var(--copper);
    }
    .footer-logo em{font-style:italic;color:var(--text2)}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{
      font-family:var(--fm);font-size:.6rem;letter-spacing:.12em;
      text-transform:uppercase;color:var(--muted);text-decoration:none;
      transition:color .2s;
    }
    .footer-links a:hover{color:var(--copper)}
    .footer-copy{
      font-family:var(--fm);font-size:.6rem;color:var(--muted);
    }

    /* ╔══════════════════════════════════════════╗
       ║  SCROLL REVEAL                           ║
       ╚══════════════════════════════════════════╝ */
    .reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
    .reveal.in{opacity:1;transform:translateY(0)}
    .reveal-delay-1{transition-delay:.1s}
    .reveal-delay-2{transition-delay:.2s}
    .reveal-delay-3{transition-delay:.3s}

    /* ── RESPONSIVE ── */
    @@media(max-width:1024px){
      .courses-grid{grid-template-columns:repeat(2,1fr)}
      .roles-grid{grid-template-columns:1fr}
      .testi-grid{grid-template-columns:1fr}
    }
    @@media(max-width:768px){
      nav{padding:1rem 1.5rem}
      .nav-links{display:none}
      #hero{padding:6rem 1.5rem 4rem}
      .hero-inner{grid-template-columns:1fr}
      .hero-right{display:none}
      #stats{grid-template-columns:repeat(2,1fr)}
      .stat:nth-child(2){border-right:none}
      #courses{padding:5rem 1.5rem}
      .roles-inner{padding:0 1.5rem}
      .courses-grid{grid-template-columns:1fr}
      #testi{padding:4rem 1.5rem}
      .testi-grid{grid-template-columns:1fr}
      #cta{margin:0 1.5rem 4rem;padding:3rem 1.5rem}
      footer{flex-direction:column;align-items:flex-start}
    }
  </style>
</head>
<body>

<div id="cur"></div>

<!-- NAV -->
<nav id="nav">
  <a href="index.html" class="nav-logo">Edu<em>Verse</em></a>
  <ul class="nav-links" style="display:flex; align-items:center;">
    <li><a href="#courses">Eğitimler</a></li>
    <li><a href="#roles">Roller</a></li>
    <li><a href="#testi">Yorumlar</a></li>
    <li><a href="/Hesap/Giris" style="color:var(--copper); font-weight:700;">Giriş Yap</a></li>
  </ul>
  <a href="/Hesap/KayitOgrenci" class="nav-cta">Kayıt Ol</a>
</nav>

<!-- THEME TOGGLE (FIXED) -->
<div style="position:fixed; top:7rem; right:1.2rem; z-index:1000;">
  <div class="theme-toggle" title="Tema değiştir" style="padding:4px 8px;">
    <span class="theme-toggle-icon">🌙</span>
    <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
  </div>
</div>

<!-- HERO -->
<section id="hero">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <div class="hero-inner">
    <div class="hero-left">
      <span class="hero-eyebrow">Türkiye'nin Yeni Eğitim Ekosistemi</span>
      <h1 class="hero-title">
        Öğren.<br>
        <em>Öğret.</em><br>
        Dönüştür.
      </h1>
      <p class="hero-subtitle">
        Öğrenciler büyür, öğretmenler ilham verir.
        İki rol, bir ekosistem, sonsuz olasılık.
      </p>
      <div class="hero-actions">
        <a href="#courses" class="btn-copper">Eğitimleri Keşfet</a>
        <a href="/Hesap/KayitOgrenci" class="btn-glass">Ücretsiz Başla</a>
      </div>
      <div class="hero-trust">
        <div class="trust-avatars">
          <div class="trust-av">🧑‍💻</div>
          <div class="trust-av">👩‍🎨</div>
          <div class="trust-av">👨‍🔬</div>
          <div class="trust-av">👩‍💼</div>
        </div>
        <span>+@Model.BuAyKatilanOgrenciSayisi öğrenci bu ay katıldı</span>
      </div>
    </div>

    <div class="hero-right">
      <div class="deck-scene" id="deckScene">
        <!-- Card 1 — Öğrenci -->
        <div class="deck-card">
          <span class="dc-icon">🎓</span>
          <span class="dc-badge dc-badge-copper">Öğrenci</span>
          <div class="dc-title">Öğrenmeye<br>Başla</div>
          <div class="dc-desc">Yüzlerce kurs, canlı dersler ve bağışçı bursları seni bekliyor.</div>
          <div class="dc-stat">
            <span class="dc-stat-num">@Model.ToplamKursSayisi</span>
            <span class="dc-stat-label">Aktif Kurs</span>
          </div>
        </div>
        <!-- Card 2 — Öğretmen -->
        <div class="deck-card">
          <span class="dc-icon">🏆</span>
          <span class="dc-badge dc-badge-mint">Öğretmen</span>
          <div class="dc-title">İlham Ver,<br>Kazan</div>
          <div class="dc-desc">Kursunu oluştur, topluluğunu büyüt, pasif gelir elde et.</div>
          <div class="dc-stat">
            <span class="dc-stat-num" style="color:var(--mint)">₺@Model.OrtalamaAylikKazanc.ToString("N0")</span>
            <span class="dc-stat-label">Ort. Aylık Kazanç</span>
          </div>
        </div>
      </div>
      <p class="deck-hint">↓ Kaydırdıkça kart destin döner</p>
    </div>
  </div>

  <div class="scroll-pulse">
    <div class="scroll-dot"></div>
    <span>kaydır</span>
  </div>
</section>

<!-- STATS -->
<div id="stats">
  <div class="stat reveal">
    <div class="stat-num" data-target="@Model.AktifOgrenciSayisi">0</div>
    <div class="stat-label">Aktif Öğrenci</div>
  </div>
  <div class="stat reveal reveal-delay-1">
    <div class="stat-num" data-target="@Model.UzmanEgitmenSayisi">0</div>
    <div class="stat-label">Uzman Öğretmen</div>
  </div>
  <div class="stat reveal reveal-delay-2">
    <div class="stat-num" data-target="@Model.ToplamKursSayisi">0</div>
    <div class="stat-label">Eğitim Kursu</div>
  </div>
  <div class="stat reveal reveal-delay-3">
    <div class="stat-num" data-target="@Model.TamamlananKursSayisi">0</div>
    <div class="stat-label">Tamamlanan Kurs</div>
  </div>
</div>

<!-- MARQUEE -->
<div class="marquee-wrap" aria-hidden>
  <div class="marquee-track">
    <span class="marquee-item">Öğren <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Öğret <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Büyü <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Keşfet <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">İlham Ver <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Dönüştür <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Öğren <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Öğret <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Büyü <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Keşfet <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">İlham Ver <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">Dönüştür <span class="marquee-gem">✦</span></span>
  </div>
</div>

<!-- DONOR MARQUEE -->
@if (!string.IsNullOrEmpty(Model.SonBagisciAdi))
{
<div class="marquee-wrap donor-marquee" aria-hidden>
  <div class="marquee-track" style="animation-duration: 45s; animation-direction: reverse;">
    @{
       var donorText = $"Teşekkürler! Son bağışçımız {Model.SonBagisciAdi} ({Model.SonBagisTutari.ToString("N0")}₺) ile öğrenim havuzumuz daha da büyüdü!";
    }
    <span class="marquee-item">@donorText <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">@donorText <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">@donorText <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">@donorText <span class="marquee-gem">✦</span></span>
    <span class="marquee-item">@donorText <span class="marquee-gem">✦</span></span>
  </div>
</div>
}

<!-- COURSES -->
<section id="courses">
  <div class="section-top">
    <div>
      <p class="eyebrow">Öne Çıkan Eğitimler</p>
      <h2 class="section-title reveal">Şimdi <em>Başla</em></h2>
    </div>
    <div class="filters" style="margin-left: 2rem; margin-right: 2rem; flex-wrap: wrap; justify-content: flex-end;">
      <button class="filter active" data-filter="all" onclick="setFilter(this)">Tümü</button>
      @foreach (var kategori in Model.Kategoriler)
      {
          <button class="filter" data-filter="@kategori.Ad.ToLower()" onclick="setFilter(this)">@kategori.Ad</button>
      }
    </div>
  </div>

  <div class="courses-grid" id="coursesGrid">
    @{ int index = 1; }
    @foreach (var kurs in Model.YayinliKurslar.Take(12))
    {
        string badgeClass = index % 3 == 1 ? "b-copper" : index % 3 == 2 ? "b-mint" : "b-blue";
        string delayClass = index % 3 == 1 ? "" : index % 3 == 2 ? "reveal-delay-1" : "reveal-delay-2";

        <div class="course-card reveal @delayClass" data-kategori="@kurs.KategoriAdi.ToLower()">
          <div class="card-top">
            <span class="card-badge @badgeClass">@kurs.KategoriAdi</span>
            <span class="card-num">@(index.ToString("D2"))</span>
          </div>
          <h3 class="card-title">@kurs.Kurs.Baslik</h3>
          <p class="card-instructor">@kurs.EgitmenAdi</p>
          <div class="card-stars">★★★★★ <span>(@kurs.YorumSayisi yorum)</span></div>
          <div class="card-meta">
            <span>⏱ @(kurs.Kurs.Aciklama.Length > 60 ? kurs.Kurs.Aciklama.Substring(0, 60) + "..." : kurs.Kurs.Aciklama)</span>
          </div>
          <div class="card-footer">
            <div class="card-price-wrap">
              @if (kurs.Kurs.Fiyat > 0)
              {
                <span class="card-price">₺@kurs.Kurs.Fiyat.ToString("N0")</span>
              }
              else
              {
                <span class="card-free">Ücretsiz</span>
              }
            </div>
            <a href="/Hesap/Giris" class="card-enroll" style="text-decoration:none;">Hemen Katıl →</a>
          </div>
        </div>
        index++;
    }
  </div>

  <!-- Boş sonuç mesajı -->
  <div id="emptyState" style="display:none; text-align:center; padding:4rem 2rem; color:var(--text2); font-family:var(--fm); font-size:.85rem; letter-spacing:.08em;">
    <div style="font-size:3rem; margin-bottom:1rem; opacity:.4;">📭</div>
    <p>Bu kategoride henüz yayında kurs bulunamadı.</p>
  </div>
</section>

<!-- ROLES -->
<section id="roles">
  <div class="roles-bg"></div>
  <div class="roles-inner">
    <p class="eyebrow reveal">Platforma Nasıl Katılırsın?</p>
    <h2 class="section-title reveal">Rolünü <em>Seç</em></h2>
    <div class="roles-grid">
      <div class="role-card role-card-1 reveal">
        <span class="role-num">01</span>
        <div class="role-icon-wrap ri-copper">🎓</div>
        <h3 class="role-title">Öğrenci</h3>
        <p class="role-desc">Yüzlerce kurs, canlı dersler ve bağışçı burslarıyla kariyer hedeflerine ulaş. Kendi hızında, kendi yolunda.</p>
        <ul class="role-perks">
          <li><span class="rp-dot" style="background:var(--copper)"></span>Ücretsiz başlangıç, kredi kartı gerekmez</li>
          <li><span class="rp-dot" style="background:var(--copper)"></span>Bağışçı burslarıyla ücretli kurslara ücretsiz eriş</li>
          <li><span class="rp-dot" style="background:var(--copper)"></span>Her kurs sonunda sertifika</li>
        </ul>
        <a href="/Hesap/KayitOgrenci" class="role-link role-link-copper">Öğrenci Ol →</a>
      </div>

      <div class="role-card role-card-2 reveal reveal-delay-1">
        <span class="role-num">02</span>
        <div class="role-icon-wrap ri-mint">🏆</div>
        <h3 class="role-title">Öğretmen</h3>
        <p class="role-desc">Bilgini paylaş, topluluk oluştur ve kendi kurslarından gelir elde et. Stüdyo kalitesinde araçlar ücretsiz.</p>
        <ul class="role-perks">
          <li><span class="rp-dot" style="background:var(--mint)"></span>%70 gelir payı, satışların sende kalır</li>
          <li><span class="rp-dot" style="background:var(--mint)"></span>Video, canlı ve hibrit ders formatları</li>
          <li><span class="rp-dot" style="background:var(--mint)"></span>Gerçek zamanlı analitik panel</li>
        </ul>
        <a href="/Hesap/KayitEgitmen" class="role-link role-link-mint">Öğretmen Ol →</a>
      </div>

      <div class="role-card role-card-3 reveal reveal-delay-2">
        <span class="role-num">03</span>
        <div class="role-icon-wrap ri-blue">🔑</div>
        <h3 class="role-title">Zaten Üye Misin?</h3>
        <p class="role-desc">Kaldığın yerden devam et. Öğrendiklerinle dünyanı değiştirmek için şimdi tam zamanı.</p>
        <ul class="role-perks">
          <li><span class="rp-dot" style="background:var(--blue)"></span>Kurslarına kaldığın yerden devam et</li>
          <li><span class="rp-dot" style="background:var(--blue)"></span>İlerlemelerini detaylı görüntüle</li>
          <li><span class="rp-dot" style="background:var(--blue)"></span>Güvenli hesaba hızlı profil bağlantısı</li>
        </ul>
        <a href="/Hesap/Giris" class="role-link role-link-blue">Giriş Yap →</a>
      </div>

    </div>
    
    <div style="display:flex; justify-content:center; gap:1.5rem; margin-top:1.5rem; flex-wrap:wrap;">
      <div class="role-card role-card-3 reveal reveal-delay-3" style="border-color:rgba(167,139,250,.2); flex:1 1 280px; max-width:392px;">
        <span class="role-num">04</span>
        <div class="role-icon-wrap" style="background:rgba(167,139,250,.12);color:#a78bfa;">🛡️</div>
        <h3 class="role-title">Yönetici</h3>
        <p class="role-desc">Platform yöneticisi olarak sistemi kontrol edin, kullanıcıları ve kursları yönetin.</p>
        <ul class="role-perks">
          <li><span class="rp-dot" style="background:#a78bfa"></span>Tüm kullanıcı ve kurs yönetimi</li>
          <li><span class="rp-dot" style="background:#a78bfa"></span>Bağış havuzu ve gelir takibi</li>
          <li><span class="rp-dot" style="background:#a78bfa"></span>Platform istatistikleri ve raporlar</li>
        </ul>
        <a href="/Hesap/AdminGiris" class="role-link" style="color:#a78bfa;border-color:rgba(167,139,250,.3);">Yönetici Girişi →</a>
      </div>

      <!-- Bağışçı Kartı -->
      <div class="role-card role-card-4 reveal reveal-delay-4" style="border-color:rgba(232,146,74,.2); flex:1 1 280px; max-width:392px;">
        <span class="role-num">05</span>
        <div class="role-icon-wrap" style="background:rgba(232,146,74,.12);color:#e8924a;">💝</div>
        <h3 class="role-title">Bağışçı</h3>
        <p class="role-desc">Öğrencilerin eğitimlerine destek olmak ve yeni nesillerin hayatına dokunmak için bağışçı olun.</p>
        <ul class="role-perks">
          <li><span class="rp-dot" style="background:#e8924a"></span>Öğrencilere burs imkanı</li>
          <li><span class="rp-dot" style="background:#e8924a"></span>Platform havuzuna destek</li>
          <li><span class="rp-dot" style="background:#e8924a"></span>Tamamen şeffaf liste</li>
        </ul>
        <a href="/Bagisci/BagisPanel" class="role-link" style="color:#e8924a;border-color:rgba(232,146,74,.3);">Bağış Yap →</a>
      </div>

  </div>
</section>

<!-- TESTIMONIALS -->
<section id="testi">
  <p class="eyebrow reveal">Kullanıcı Yorumları</p>
  <h2 class="section-title reveal">Ne <em>Dediler?</em></h2>
  <div class="testi-grid">
    <div class="testi-card reveal">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"6 ay içinde kariyerimi tamamen değiştirdim. Python kursu inanılmaz içerik kalitesine sahip."</p>
      <div class="testi-person">
        <div class="testi-av">👩‍💻</div>
        <div><div class="testi-name">Zeynep K.</div><div class="testi-role">Data Scientist · İstanbul</div></div>
      </div>
    </div>
    <div class="testi-card reveal reveal-delay-1">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"Öğretmen olarak ayda ortalama ₺7.000 kazanıyorum. Platform gerçekten işe yarıyor."</p>
      <div class="testi-person">
        <div class="testi-av">👨‍🏫</div>
        <div><div class="testi-name">Mehmet A.</div><div class="testi-role">UI/UX Öğretmeni · Ankara</div></div>
      </div>
    </div>
    <div class="testi-card reveal reveal-delay-2">
      <div class="testi-stars">★★★★★</div>
      <p class="testi-quote">"Bağışçı olarak desteklediğim öğrencinin ilerleyişini görebilmek paha biçilemez bir duygu."</p>
      <div class="testi-person">
        <div class="testi-av">💼</div>
        <div><div class="testi-name">Elif M.</div><div class="testi-role">Bağışçı · İzmir</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<div id="cta">
  <h2 class="cta-title reveal">Hemen <em>Başla,</em><br>Bedavaya.</h2>
  <p class="cta-sub reveal">Kredi kartı gerekmez. İlk 3 ders tamamen ücretsiz. Sadece öğrenmek için giriş yap.</p>
  <div class="cta-btns reveal">
    <a href="/Hesap/KayitOgrenci" class="btn-copper">Öğrenci Ol</a>
    <a href="/Hesap/KayitEgitmen" class="btn-glass">Öğretmen Ol</a>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">Edu<em>Verse</em></div>
  <nav class="footer-links">
    <a href="/Hesap/KayitOgrenci">Öğrenci</a>
    <a href="/Hesap/KayitEgitmen">Öğretmen</a>
  </nav>
  <p class="footer-copy">© 2026 EduVerse — Tüm Hakları Saklıdır</p>
</footer>

<script>
/* ── CURSOR ── */
const cur = document.getElementById('cur')
document.addEventListener('mousemove', e => {
  cur.style.left = e.clientX + 'px'
  cur.style.top  = e.clientY + 'px'
})
document.querySelectorAll('a,button,.course-card,.role-card,.testi-card').forEach(el => {
  el.addEventListener('mouseenter', () => cur.classList.add('big'))
  el.addEventListener('mouseleave', () => cur.classList.remove('big'))
})

/* ── NAV SHRINK ── */
const nav = document.getElementById('nav')
window.addEventListener('scroll', () => {
  nav.classList.toggle('shrunk', window.scrollY > 60)
}, { passive: true })

/* ── SCROLL REVEAL ── */
const revealObs = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('in'), i * 60)
    }
  })
}, { threshold: 0.1 })
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el))

/* ── COUNTER ── */
function animateCount(el, target) {
  let start = null
  const duration = 1800
  const step = ts => {
    if (!start) start = ts
    const p = Math.min((ts - start) / duration, 1)
    const eased = 1 - Math.pow(1 - p, 3)
    el.textContent = Math.floor(eased * target).toLocaleString('tr-TR')
    if (p < 1) requestAnimationFrame(step)
  }
  requestAnimationFrame(step)
}
const countObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      animateCount(e.target, +e.target.dataset.target)
      countObs.unobserve(e.target)
    }
  })
}, { threshold: 0.5 })
document.querySelectorAll('[data-target]').forEach(el => countObs.observe(el))

/* ── 3D CARD DECK — SCROLL DRIVEN ── */
const cards = document.querySelectorAll('.deck-card')
const cardTransforms = [
  { tx: 30, ty:   0, rx:  5, ry: -12, filter: '' },
  { tx:  0, ty:  40, rx:  5, ry:   4, filter: 'brightness(.85)' },
  { tx:-30, ty:  80, rx:  5, ry:  16, filter: 'brightness(.7)' },
]
let deckTicking = false
window.addEventListener('scroll', () => {
  if (deckTicking) return
  deckTicking = true
  requestAnimationFrame(() => {
    const sc = window.scrollY
    const t = Math.min(sc / 600, 1) // 0→1 as we scroll 600px

    cards.forEach((card, i) => {
      const base = cardTransforms[i]
      // fan out on scroll
      const fanX = base.tx * (1 - t * .4)
      const fanY = base.ty + t * i * 20
      const fanRY = base.ry + t * i * 8
      const fanRX = base.rx - t * 5
      const scale = 1 + (i === 0 ? t * .04 : 0)
      card.style.transform = `translateX(${fanX}px) translateY(${fanY}px) rotateX(${fanRX}deg) rotateY(${fanRY}deg) scale(${scale})`
      card.style.filter = i === 0 ? '' : `brightness(${.85 - i * .1 + t * i * .1})`
    })
    deckTicking = false
  })
}, { passive: true })

/* ── FILTER BUTTONS ── */
function setFilter(btn) {
  // Aktif butonu güncelle
  document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'))
  btn.classList.add('active')

  const secilen = btn.dataset.filter
  const kartlar = document.querySelectorAll('#coursesGrid .course-card')
  let gorunenSayisi = 0

  kartlar.forEach(kart => {
    const kartKategori = kart.dataset.kategori
    const eslesiyorMu = secilen === 'all' || kartKategori === secilen

    if (eslesiyorMu) {
      kart.style.display = ''
      // Yumuşak belirim animasyonu
      kart.style.opacity = '0'
      kart.style.transform = 'translateY(16px)'
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          kart.style.transition = 'opacity .35s ease, transform .35s ease'
          kart.style.opacity = '1'
          kart.style.transform = 'translateY(0)'
        })
      })
      gorunenSayisi++
    } else {
      kart.style.transition = 'opacity .2s ease'
      kart.style.opacity = '0'
      setTimeout(() => { kart.style.display = 'none' }, 200)
    }
  })

  // Boş durum mesajı
  document.getElementById('emptyState').style.display = gorunenSayisi === 0 ? 'block' : 'none'
}
</script>
</body>
</html>
