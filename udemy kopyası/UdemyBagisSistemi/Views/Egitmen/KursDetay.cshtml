@{
    Layout = null;
    var kurs = (UdemyBagisSistemi.Models.Kurs)ViewBag.Kurs;
    var bolumler = (List<UdemyBagisSistemi.Models.KursBolumu>)ViewBag.Bolumler;
    var kategoriler = (List<UdemyBagisSistemi.Models.Kategori>)ViewBag.Kategoriler;
}
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@kurs.Baslik — Kurs Yönetimi | EduVerse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;1,400&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
  <script src="~/js/theme.js" asp-append-version="true"></script>
<style>
  :root {
    --bg:      #0d1117;
    --bg2:     #111827;
    --surface: rgba(255,255,255,0.04);
    --surfaceH:rgba(255,255,255,0.07);
    --border:  rgba(255,255,255,0.08);
    --borderH: rgba(255,255,255,0.15);
    --text:    #e6edf3;
    --text2:   #8b949e;
    --muted:   #484f58;
    --mint:    #3dffc0;
    --mint2:   rgba(61,255,192,.08);
    --copper:  #e8924a;
    --red:     #ff6b6b;
    --red2:    rgba(255,107,107,.1);
    --fh: 'Cormorant Garamond', serif;
    --fs: 'Plus Jakarta Sans', sans-serif;
    --fm: 'JetBrains Mono', monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--fs);
    background: var(--bg);
    color: var(--text);
    display: flex;
    height: 100vh;
    overflow: hidden;
    cursor: none;
  }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--mint); }

  /* ── CURSOR ── */
  #cur {
    position: fixed; width: 12px; height: 12px; border-radius: 50%;
    background: var(--mint); pointer-events: none; z-index: 9999;
    transform: translate(-50%,-50%); transition: width .15s, height .15s, opacity .15s;
    mix-blend-mode: screen;
  }
  #cur.grow { width: 28px; height: 28px; opacity: .5; }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 260px; min-width: 260px; background: var(--bg2);
    border-right: 1px solid var(--border);
    padding: 2rem 1.5rem;
    display: flex; flex-direction: column; gap: 1.5rem;
    height: 100vh; overflow-y: auto;
  }
  .logo { font-family: var(--fh); font-size: 1.8rem; color: var(--mint); text-decoration: none; font-weight: 700; }
  .logo em { font-style: italic; }
  .back-btn {
    display: flex; align-items: center; gap: .6rem;
    color: var(--text2); text-decoration: none; font-size: .9rem;
    padding: .7rem 1rem; border-radius: 10px;
    background: var(--surface); border: 1px solid var(--border);
    transition: all .2s;
  }
  .back-btn:hover { color: var(--mint); border-color: var(--mint); }

  .kurs-meta { padding: 1.2rem; background: var(--surface); border-radius: 12px; border: 1px solid var(--border); }
  .kurs-meta h3 { font-family: var(--fh); font-size: 1.4rem; color: var(--mint); margin-bottom: .5rem; line-height: 1.2; }
  .kurs-meta p  { font-size: .8rem; color: var(--text2); font-family: var(--fm); }

  .badge {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .3rem .8rem; border-radius: 20px; font-size: .75rem; font-weight: 700;
  }
  .badge-green { background: var(--mint2); color: var(--mint); }
  .badge-copper { background: rgba(232,146,74,.1); color: var(--copper); }

  .sidebar-nav { list-style: none; display: flex; flex-direction: column; gap: .3rem; margin-top: auto; }
  .sidebar-nav li a {
    display: block; padding: .7rem 1rem; border-radius: 10px;
    color: var(--text2); text-decoration: none; font-size: .9rem;
    transition: all .2s;
  }
  .sidebar-nav li a:hover { color: var(--text); background: var(--surfaceH); }
  .sidebar-nav li a.danger { color: var(--red); }
  .sidebar-nav li a.danger:hover { background: var(--red2); }

  /* ── MAIN ── */
  .main {
    flex: 1; height: 100vh; overflow-y: auto;
    background: radial-gradient(circle at 80% 10%, rgba(61,255,192,.04), transparent 500px);
  }
  .main-inner { max-width: 1000px; margin: 0 auto; padding: 3rem 3.5rem; }

  /* ── FLASH ── */
  .flash { padding: 1rem 1.4rem; border-radius: 12px; margin-bottom: 2rem; font-weight: 500; font-size: .95rem; }
  .flash-ok  { background: var(--mint2); border: 1px solid rgba(61,255,192,.2); color: var(--mint); }
  .flash-err { background: var(--red2);  border: 1px solid rgba(255,107,107,.2); color: var(--red); }

  /* ── SECTION HEADING ── */
  .sec-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .sec-head h2 { font-family: var(--fh); font-size: 2rem; }
  .sec-head h2 em { color: var(--mint); font-style: italic; }

  /* ── CARD ── */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 16px; padding: 2rem; margin-bottom: 2rem;
  }
  .card-title { font-family: var(--fh); font-size: 1.5rem; color: var(--mint); margin-bottom: 1.5rem; }

  /* ── FORM ── */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .form-group { margin-bottom: 1.2rem; }
  .form-group.full { grid-column: 1 / -1; }
  label.lbl { display: block; margin-bottom: .5rem; font-size: .85rem; font-weight: 600; color: var(--text2); letter-spacing: .03em; }
  input[type=text], input[type=number], select, textarea {
    width: 100%; padding: .85rem 1.1rem; border-radius: 10px;
    border: 1px solid var(--border); background: rgba(0,0,0,.25);
    color: var(--text); font-family: var(--fs); font-size: .92rem;
    transition: border-color .2s, box-shadow .2s;
  }
  input:focus, select:focus, textarea:focus {
    outline: none; border-color: var(--mint); box-shadow: 0 0 0 3px var(--mint2);
  }
  select option { background: var(--bg2); }
  textarea { resize: vertical; min-height: 110px; }

  .file-zone {
    display: block; border: 2px dashed var(--borderH); border-radius: 12px;
    padding: 1.5rem 1rem; text-align: center; color: var(--text2);
    cursor: none; transition: all .25s;
  }
  .file-zone:hover { border-color: var(--mint); background: var(--mint2); color: var(--mint); }
  .file-zone input { display: none; }
  .file-zone .icon { font-size: 1.8rem; display: block; margin-bottom: .4rem; }
  .file-zone .hint { font-size: .82rem; }
  .file-zone .hint strong { color: var(--mint); }

  .toggle-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.2rem; border-radius: 10px;
    background: var(--mint2); border: 1px solid rgba(61,255,192,.15);
  }
  .toggle-row input[type=checkbox] { width: 18px; height: 18px; accent-color: var(--mint); cursor: none; }
  .toggle-row label { color: var(--text); font-weight: 600; font-size: .9rem; cursor: none; }
  .toggle-row small { display: block; color: var(--text2); font-size: .78rem; }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .8rem 1.6rem; border-radius: 100px;
    font-weight: 700; font-size: .88rem; border: none; cursor: none;
    transition: transform .2s, box-shadow .2s, background .2s;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn-primary { background: var(--mint); color: #000; }
  .btn-primary:hover { box-shadow: 0 6px 20px rgba(61,255,192,.35); }
  .btn-ghost { background: transparent; border: 1px solid var(--borderH); color: var(--text2); }
  .btn-ghost:hover { color: var(--text); background: var(--surfaceH); }
  .btn-danger { background: var(--red2); border: 1px solid rgba(255,107,107,.3); color: var(--red); }
  .btn-danger:hover { background: rgba(255,107,107,.2); box-shadow: 0 4px 14px rgba(255,107,107,.2); }
  .btn-sm { padding: .5rem 1rem; font-size: .82rem; border-radius: 8px; }

  /* ── BOLUM LIST ── */
  .bolum-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .bolum-item {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 14px; padding: 1.4rem 1.6rem;
    transition: border-color .2s;
  }
  .bolum-item:hover { border-color: var(--borderH); }
  .bolum-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: .6rem; }
  .bolum-num { font-family: var(--fm); font-size: .78rem; color: var(--mint); font-weight: 700; }
  .bolum-title { font-size: 1.05rem; font-weight: 600; color: var(--text); }
  .bolum-desc  { font-size: .88rem; color: var(--text2); margin-bottom: .8rem; }
  .bolum-links { display: flex; gap: .6rem; flex-wrap: wrap; }
  .bolum-link {
    font-size: .78rem; font-family: var(--fm); padding: .3rem .7rem; border-radius: 6px;
    text-decoration: none; color: var(--text2); background: var(--surface); border: 1px solid var(--border);
    transition: all .2s;
  }
  .bolum-link:hover { color: var(--mint); border-color: var(--mint); }
  .bolum-actions { display: flex; gap: .5rem; flex-shrink: 0; }

  /* ── MODAL ── */
  .overlay {
    position: fixed; inset: 0; background: rgba(10,14,20,.85); backdrop-filter: blur(10px);
    z-index: 800; display: none; justify-content: center; align-items: center;
    opacity: 0; transition: opacity .25s;
  }
  .overlay.open { display: flex; opacity: 1; }
  .modal-box {
    background: var(--bg2); border: 1px solid var(--border); border-radius: 20px;
    padding: 2.5rem; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto;
    transform: translateY(24px); transition: transform .25s;
    position: relative; box-shadow: 0 24px 60px rgba(0,0,0,.6);
  }
  .overlay.open .modal-box { transform: translateY(0); }
  .modal-close {
    position: absolute; top: 1.2rem; right: 1.2rem;
    background: var(--surface); border: none; color: var(--text2);
    width: 34px; height: 34px; border-radius: 50%; font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    cursor: none; transition: all .2s;
  }
  .modal-close:hover { background: var(--surfaceH); color: var(--mint); transform: rotate(90deg); }
  .modal-title { font-family: var(--fh); font-size: 1.8rem; color: var(--mint); margin-bottom: .4rem; }
  .modal-sub   { font-size: .88rem; color: var(--text2); margin-bottom: 1.8rem; }

  /* ── EMPTY ── */
  .empty { text-align: center; padding: 3rem; color: var(--text2); }
  .empty .ei { font-size: 3rem; margin-bottom: 1rem; opacity: .4; }

  hr.divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  /* ── VIDEO MODAL ── */
  .video-modal-box {
    background: var(--bg2); border: 1px solid var(--border); border-radius: 20px;
    width: 95%; max-width: 960px; max-height: 92vh; overflow: hidden;
    display: flex; flex-direction: column;
    transform: translateY(24px); transition: transform .25s;
    position: relative; box-shadow: 0 24px 60px rgba(0,0,0,.6);
  }
  .overlay.open .video-modal-box { transform: translateY(0); }

  .vm-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 1.6rem; border-bottom: 1px solid var(--border); flex-shrink: 0;
  }
  .vm-header h3 { font-family: var(--fh); font-size: 1.4rem; color: var(--mint); }
  .vm-header .vm-badge {
    font-family: var(--fm); font-size: .72rem; padding: .25rem .7rem;
    border-radius: 20px; background: var(--mint2); color: var(--mint);
  }

  .vm-body { display: flex; flex: 1; min-height: 0; overflow: hidden; }

  .vm-video-col {
    flex: 1.2; display: flex; flex-direction: column;
    border-right: 1px solid var(--border); min-width: 0;
  }
  .vm-video-wrap {
    background: #000; aspect-ratio: 16/9; max-height: 420px;
    display: flex; align-items: center; justify-content: center;
  }
  .vm-video-wrap video { width: 100%; height: 100%; object-fit: contain; }
  .vm-video-info {
    padding: 1rem 1.4rem; border-top: 1px solid var(--border);
    font-size: .85rem; color: var(--text2); flex-shrink: 0;
  }

  .vm-comments-col {
    flex: .8; display: flex; flex-direction: column;
    min-width: 280px; max-width: 380px;
  }
  .vm-comments-header {
    padding: 1rem 1.2rem; border-bottom: 1px solid var(--border);
    font-weight: 700; font-size: .9rem; color: var(--text);
    display: flex; align-items: center; gap: .5rem; flex-shrink: 0;
  }
  .vm-comments-header .count {
    font-family: var(--fm); font-size: .75rem;
    background: var(--surface); padding: .2rem .6rem; border-radius: 12px; color: var(--text2);
  }

  .vm-comments-list {
    flex: 1; overflow-y: auto; padding: 1rem 1.2rem;
    display: flex; flex-direction: column; gap: .8rem;
  }
  .vm-comments-list::-webkit-scrollbar { width: 4px; }
  .vm-comments-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 2px; }

  .cmt-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: .9rem 1rem;
  }
  .cmt-head { display: flex; align-items: center; gap: .5rem; margin-bottom: .4rem; flex-wrap: wrap; }
  .cmt-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; font-weight: 700; flex-shrink: 0;
  }
  .cmt-avatar.ogrenci { background: rgba(232,146,74,.15); color: var(--copper); }
  .cmt-avatar.egitmen { background: var(--mint2); color: var(--mint); }
  .cmt-name { font-weight: 600; font-size: .84rem; }
  .cmt-role {
    font-family: var(--fm); font-size: .65rem; padding: .15rem .5rem;
    border-radius: 20px; font-weight: 700;
  }
  .cmt-role.egitmen { background: var(--mint2); color: var(--mint); }
  .cmt-role.ogrenci { background: rgba(232,146,74,.08); color: var(--copper); }
  .cmt-date { font-size: .72rem; color: var(--muted); margin-left: auto; font-family: var(--fm); }
  .cmt-text { font-size: .86rem; color: var(--text); line-height: 1.55; margin-bottom: .5rem; }

  .cmt-reply-btn {
    background: none; border: none; color: var(--mint); font-size: .78rem;
    font-weight: 600; cursor: pointer; padding: .2rem 0; transition: opacity .2s;
  }
  .cmt-reply-btn:hover { opacity: .7; }

  .cmt-reply-form { display: none; margin-top: .6rem; gap: .4rem; flex-direction: column; }
  .cmt-reply-form.open { display: flex; }
  .cmt-reply-input {
    width: 100%; padding: .6rem .8rem; border-radius: 8px;
    border: 1px solid var(--border); background: rgba(0,0,0,.3);
    color: var(--text); font-family: var(--fs); font-size: .84rem;
    resize: none; min-height: 60px; transition: border-color .2s;
  }
  .cmt-reply-input:focus { border-color: var(--mint); outline: none; box-shadow: 0 0 0 2px var(--mint2); }
  .cmt-reply-send {
    align-self: flex-end; padding: .45rem 1rem; border-radius: 8px;
    background: var(--mint); color: #000; border: none;
    font-weight: 700; font-size: .78rem; cursor: pointer;
    transition: transform .15s, box-shadow .15s;
  }
  .cmt-reply-send:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(61,255,192,.3); }

  .cmt-replies {
    margin-top: .6rem; padding-left: .8rem;
    border-left: 2px solid var(--mint2);
    display: flex; flex-direction: column; gap: .5rem;
  }
  .cmt-reply-card {
    background: rgba(61,255,192,.03); border: 1px solid rgba(61,255,192,.08);
    border-radius: 10px; padding: .7rem .9rem;
  }

  .vm-empty {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; flex: 1; color: var(--muted);
    gap: .5rem; text-align: center; padding: 2rem;
  }
  .vm-empty .vm-ei { font-size: 2.5rem; opacity: .3; }

  @@media (max-width: 768px) {
    .vm-body { flex-direction: column; }
    .vm-video-col { border-right: none; border-bottom: 1px solid var(--border); }
    .vm-comments-col { max-width: 100%; }
  }
</style>
</head>
<body>

<div id="cur"></div>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <a href="/" class="logo">Edu<em>Verse</em></a>

  <a href="/Egitmen/Panel" class="back-btn">← Eğitmen Paneline Dön</a>

  <div class="kurs-meta">
    <h3>@kurs.Baslik</h3>
    <p style="margin-bottom:.8rem;">Kurs No: #@kurs.Id</p>
    @if (kurs.YayinlandiMi)
    {
        <span class="badge badge-green">● Yayında</span>
    }
    else
    {
        <span class="badge badge-copper">◌ Taslak</span>
    }
  </div>

  <ul class="sidebar-nav">
    <li><a href="#kurs-bilgileri">📋 Kurs Bilgileri</a></li>
    <li><a href="#bolumler">🎬 Bölümler / Videolar</a></li>
    <li><a href="#yayin">📡 Yayın Durumu</a></li>
    <li style="margin-top:1rem;">
      <a href="#" class="danger" onclick="showSilModal(event)">🗑 Kursu Sil</a>
    </li>
    <li style="margin-top:auto;">
      <div class="theme-toggle" title="Tema değiştir" style="padding:0.5rem 1rem;">
        <span class="theme-toggle-icon">🌙</span>
        <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
        <span class="theme-toggle-label">Koyu</span>
      </div>
    </li>
  </ul>
</aside>

<!-- ══ MAIN ══ -->
<main class="main" id="mainScroll">
  <div class="main-inner">

    <!-- Flash Messages -->
    @if (TempData["Mesaj"] != null)
    {
        <div class="flash flash-ok">✓ @TempData["Mesaj"]</div>
    }
    @if (TempData["Hata"] != null)
    {
        <div class="flash flash-err">✕ @TempData["Hata"]</div>
    }

    <!-- ── KURS BİLGİLERİ ── -->
    <div id="kurs-bilgileri" class="card">
      <div class="sec-head">
        <h2><em>Kurs</em> Bilgileri</h2>
      </div>

      <form action="/Egitmen/KursGuncelle" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kursId" value="@kurs.Id" />

        <div class="form-row">
          <div class="form-group full">
            <label class="lbl">Kurs Başlığı</label>
            <input type="text" name="baslik" value="@kurs.Baslik" required />
          </div>
          <div class="form-group">
            <label class="lbl">Kategori</label>
            <select name="kategoriId" required>
              @foreach (var kat in kategoriler)
              {
                  if (kat.Id == kurs.KategoriId)
                  {
                      <option value="@kat.Id" selected>@kat.Ad</option>
                  }
                  else
                  {
                      <option value="@kat.Id">@kat.Ad</option>
                  }
              }
            </select>
          </div>
          <div class="form-group">
            <label class="lbl">Fiyat (₺)</label>
            <input type="number" step="0.01" name="fiyat" value="@kurs.Fiyat" required />
          </div>
          <div class="form-group full">
            <label class="lbl">Açıklama</label>
            <textarea name="aciklama" required>@kurs.Aciklama</textarea>
          </div>
        </div>

        <div class="form-row" style="margin-bottom:1.5rem;">
          <div class="form-group">
            <label class="lbl">Yeni Önizleme Videosu (değiştirmek için seç)</label>
            <label class="file-zone">
              <span class="icon">🎬</span>
              <span class="hint">Mevcut: <strong>@(string.IsNullOrEmpty(kurs.OnizlemeVideoUrl) ? "Yok" : "Var")</strong> — Değiştirmek için seç</span>
              <input type="file" name="onizlemeVideoDosyasi" accept="video/*"
                     onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--mint)\'>Seçildi:</strong> '+this.files[0].name" />
            </label>
          </div>
          <div class="form-group">
            <label class="lbl">Yeni Küçük Resim (değiştirmek için seç)</label>
            <label class="file-zone" style="border-color:rgba(61,255,192,.3);">
              <span class="icon">🖼️</span>
              <span class="hint">Mevcut: <strong>@(string.IsNullOrEmpty(kurs.ThumbnailUrl) ? "Yok" : "Var")</strong> — Değiştirmek için seç</span>
              <input type="file" name="thumbnailDosyasi" accept="image/*"
                     onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--mint)\'>Seçildi:</strong> '+this.files[0].name" />
            </label>
          </div>
        </div>
        <div class="form-row" style="margin-bottom:1.5rem;">
          <div class="form-group">
            <label class="lbl">Yeni Ek Doküman (değiştirmek için seç)</label>
            <label class="file-zone" style="border-color:rgba(232,146,74,.3);">
              <span class="icon" style="color:var(--copper);">📄</span>
              <span class="hint">Mevcut: <strong style="color:var(--copper);">@(string.IsNullOrEmpty(kurs.DokumanUrl) ? "Yok" : "Var")</strong> — Değiştirmek için seç</span>
              <input type="file" name="dokumanDosyasi"
                     onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--copper)\'>Seçildi:</strong> '+this.files[0].name" />
            </label>
          </div>
        </div>

        <div class="toggle-row form-group" style="margin-bottom:1.5rem;">
          <input type="checkbox" id="yayinToggle" name="yayinlandiMi" value="true" @(kurs.YayinlandiMi ? "checked" : "") />
          <div>
            <label for="yayinToggle">Yayında</label>
            <small>İşaretli olduğunda kurs öğrencilere açık görünür.</small>
          </div>
        </div>

        <div style="display:flex; gap:1rem; justify-content:flex-end;">
          <a href="/Egitmen/Panel" class="btn btn-ghost">Vazgeç</a>
          <button type="submit" class="btn btn-primary">💾 Değişiklikleri Kaydet</button>
        </div>
      </form>
    </div>

    <hr class="divider" />

    <!-- ── BÖLÜMLER ── -->
    <div id="bolumler">
      <div class="sec-head">
        <h2><em>Bölümler</em> / Videolar</h2>
        <button class="btn btn-primary" onclick="openModal('addModal')">+ Yeni Bölüm</button>
      </div>

      @if (!bolumler.Any())
      {
          <div class="card empty">
            <div class="ei">🎬</div>
            <p style="font-size:1rem; margin-bottom:.5rem;">Henüz bölüm eklenmedi.</p>
            <p style="font-size:.85rem;">İlk video bölümünü yukarıdaki butona basarak oluştur.</p>
          </div>
      }
      else
      {
          <ul class="bolum-list">
          @for (int i = 0; i < bolumler.Count; i++)
          {
              var b = bolumler[i];
              <li class="bolum-item" id="bolum-@b.Id">
                <div class="bolum-head">
                  <div>
                    <div class="bolum-num">Bölüm @b.SiraNo</div>
                    <div class="bolum-title">@b.Baslik</div>
                  </div>
                  <div class="bolum-actions">
                    <button class="btn btn-ghost btn-sm" onclick="openEditModal(@b.Id, '@Html.Raw(b.Baslik.Replace("'","\\\'"))', '@Html.Raw(b.Aciklama.Replace("'","\\\'"))')">✏️ Düzenle</button>
                    <button class="btn btn-danger btn-sm" onclick="openBolumSilModal(@b.Id, @kurs.Id)">🗑</button>
                  </div>
                </div>
                <p class="bolum-desc">@b.Aciklama</p>
                <div class="bolum-links">
                  @if (!string.IsNullOrEmpty(b.VideoUrl))
                  {
                      <a href="javascript:void(0)" class="bolum-link" onclick="openVideoModal(@b.Id, '@Html.Raw(b.Baslik.Replace("'","\\\'"))', '@Html.Raw(b.VideoUrl.Replace("'","\\\'"))', '@Html.Raw(b.Aciklama.Replace("'","\\\'"))')">▶ Videoyu Gör</a>
                  }
                  @if (!string.IsNullOrEmpty(b.DokumanUrl))
                  {
                      <a href="@b.DokumanUrl" target="_blank" class="bolum-link">📄 Dokümanı Gör</a>
                  }
                </div>
              </li>
          }
          </ul>
      }
    </div>

    <hr class="divider" />

    <!-- ── YAYIN DURUMU ── -->
    <div id="yayin" class="card" style="display:flex; align-items:center; justify-content:space-between; gap:2rem;">
      <div>
        <h2 style="font-family:var(--fh); font-size:1.6rem; margin-bottom:.4rem;">
          Yayın Durumu: 
          @if (kurs.YayinlandiMi)
          {
              <em style="color:var(--mint);">Yayında ●</em>
          }
          else
          {
              <em style="color:var(--copper);">Taslak ◌</em>
          }
        </h2>
        <p style="color:var(--text2); font-size:.9rem;">
          @if (kurs.YayinlandiMi)
          {
              @:Kursunuz öğrencilere açık. Butona basarak yayından kaldırabilirsiniz.
          }
          else
          {
              @:Kursunuz gizli. En az 1 bölüm ekledikten sonra yayına alabilirsiniz.
          }
        </p>
      </div>
      <form method="post" action="/Egitmen/YayinDurumuDegistir">
        @Html.AntiForgeryToken()
        <input type="hidden" name="kursId" value="@kurs.Id" />
        <button type="submit" class="btn @(kurs.YayinlandiMi ? "btn-danger" : "btn-primary")">
          @(kurs.YayinlandiMi ? "⏸ Yayından Kaldır" : "▶ Yayına Al")
        </button>
      </form>
    </div>

  </div>
</main>

<!-- ══ MODAL: Yeni Bölüm ══ -->
<div id="addModal" class="overlay" onclick="closeOnOverlay(event,'addModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('addModal')">✕</button>
    <div class="modal-title">Yeni Bölüm Ekle</div>
    <div class="modal-sub">Kursa yeni bir video bölümü ekleyin.</div>
    <form action="/Egitmen/BolumEkleDetay" method="post" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <input type="hidden" name="kursId" value="@kurs.Id" />
      <div class="form-group">
        <label class="lbl">Bölüm Başlığı</label>
        <input type="text" name="baslik" placeholder="Örn: Giriş ve Kurulum" required />
      </div>
      <div class="form-group">
        <label class="lbl">Açıklama</label>
        <textarea name="aciklama" placeholder="Bu bölümde neler öğrenilecek?"></textarea>
      </div>
      <div class="form-group">
        <label class="lbl">Video Dosyası (Zorunlu)</label>
        <label class="file-zone">
          <span class="icon">🎬</span>
          <span class="hint">MP4 veya diğer video formatları</span>
          <input type="file" name="videoDosyasi" accept="video/*" required
                 onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--mint)\'>Seçildi:</strong> '+this.files[0].name" />
        </label>
      </div>
      <div class="form-group">
        <label class="lbl">Ek Doküman (İsteğe Bağlı)</label>
        <label class="file-zone" style="border-color:rgba(232,146,74,.3);">
          <span class="icon" style="color:var(--copper);">📄</span>
          <span class="hint">PDF, ZIP vb.</span>
          <input type="file" name="dokumanDosyasi"
                 onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--copper)\'>Seçildi:</strong> '+this.files[0].name" />
        </label>
      </div>
      <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1.5rem;">
        <button type="button" class="btn btn-ghost" onclick="closeModal('addModal')">İptal</button>
        <button type="submit" class="btn btn-primary">+ Bölüm Ekle</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ MODAL: Bölüm Düzenle ══ -->
<div id="editModal" class="overlay" onclick="closeOnOverlay(event,'editModal')">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal('editModal')">✕</button>
    <div class="modal-title">Bölümü Düzenle</div>
    <div class="modal-sub">Başlık ve açıklamayı güncelleyin; yeni dosya seçerseniz eskisi değiştirilir.</div>
    <form id="editForm" action="/Egitmen/BolumGuncelle" method="post" enctype="multipart/form-data">
      @Html.AntiForgeryToken()
      <input type="hidden" name="bolumId" id="editBolumId" />
      <input type="hidden" name="kursId" value="@kurs.Id" />
      <div class="form-group">
        <label class="lbl">Bölüm Başlığı</label>
        <input type="text" name="baslik" id="editBaslik" required />
      </div>
      <div class="form-group">
        <label class="lbl">Açıklama</label>
        <textarea name="aciklama" id="editAciklama"></textarea>
      </div>
      <div class="form-group">
        <label class="lbl">Yeni Video (seçmezsen mevcut korunur)</label>
        <label class="file-zone">
          <span class="icon">🎬</span>
          <span class="hint">Değiştirmek için seç</span>
          <input type="file" name="videoDosyasi" accept="video/*"
                 onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--mint)\'>Seçildi:</strong> '+this.files[0].name" />
        </label>
      </div>
      <div class="form-group">
        <label class="lbl">Yeni Doküman (seçmezsen mevcut korunur)</label>
        <label class="file-zone" style="border-color:rgba(232,146,74,.3);">
          <span class="icon" style="color:var(--copper);">📄</span>
          <span class="hint">Değiştirmek için seç</span>
          <input type="file" name="dokumanDosyasi"
                 onchange="this.closest('.file-zone').querySelector('.hint').innerHTML='<strong style=\'color:var(--copper)\'>Seçildi:</strong> '+this.files[0].name" />
        </label>
      </div>
      <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:1.5rem;">
        <button type="button" class="btn btn-ghost" onclick="closeModal('editModal')">İptal</button>
        <button type="submit" class="btn btn-primary">💾 Güncelle</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ MODAL: Bölüm Sil ══ -->
<div id="bolumSilModal" class="overlay" onclick="closeOnOverlay(event,'bolumSilModal')">
  <div class="modal-box" style="max-width:420px; text-align:center;">
    <button class="modal-close" onclick="closeModal('bolumSilModal')">✕</button>
    <div style="font-size:3rem; margin-bottom:1rem;">⚠️</div>
    <div class="modal-title" style="color:var(--red);">Bölümü Sil</div>
    <p style="color:var(--text2); margin:1rem 0 2rem; font-size:.92rem;">Bu bölüm kalıcı olarak silinecek. Devam etmek istiyor musunuz?</p>
    <form id="bolumSilForm" method="post" action="/Egitmen/BolumSil">
      @Html.AntiForgeryToken()
      <input type="hidden" name="bolumId" id="silBolumId" />
      <input type="hidden" name="kursId" value="@kurs.Id" />
      <div style="display:flex; gap:1rem; justify-content:center;">
        <button type="button" class="btn btn-ghost" onclick="closeModal('bolumSilModal')">Vazgeç</button>
        <button type="submit" class="btn btn-danger">🗑 Evet, Sil</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ MODAL: Kurs Sil ══ -->
<div id="kursSilModal" class="overlay" onclick="closeOnOverlay(event,'kursSilModal')">
  <div class="modal-box" style="max-width:420px; text-align:center;">
    <button class="modal-close" onclick="closeModal('kursSilModal')">✕</button>
    <div style="font-size:3rem; margin-bottom:1rem;">💀</div>
    <div class="modal-title" style="color:var(--red);">Kursu Kalıcı Sil</div>
    <p style="color:var(--text2); margin:1rem 0 2rem; font-size:.92rem;">Bu kurs ve tüm bölümleri kalıcı olarak silinecek. Bu işlem <strong style="color:var(--red);">geri alınamaz</strong>!</p>
    <form method="post" action="/Egitmen/KursSil">
      @Html.AntiForgeryToken()
      <input type="hidden" name="kursId" value="@kurs.Id" />
      <div style="display:flex; gap:1rem; justify-content:center;">
        <button type="button" class="btn btn-ghost" onclick="closeModal('kursSilModal')">Vazgeç</button>
        <button type="submit" class="btn btn-danger">💀 Evet, Kalıcı Sil</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ MODAL: Video + Yorumlar ══ -->
<div id="videoModal" class="overlay" onclick="closeOnOverlay(event,'videoModal')">
  <div class="video-modal-box">
    <div class="vm-header">
      <h3 id="vmTitle">Bölüm</h3>
      <div style="display:flex; align-items:center; gap:.8rem;">
        <span class="vm-badge" id="vmBadge">Bölüm</span>
        <button class="modal-close" onclick="closeVideoModal()">✕</button>
      </div>
    </div>
    <div class="vm-body">
      <!-- Video Column -->
      <div class="vm-video-col">
        <div class="vm-video-wrap">
          <video id="vmPlayer" controls></video>
        </div>
        <div class="vm-video-info" id="vmDesc"></div>
      </div>
      <!-- Comments Column -->
      <div class="vm-comments-col">
        <div class="vm-comments-header">
          💬 Yorumlar <span class="count" id="vmCommentCount">0</span>
        </div>
        <div class="vm-comments-list" id="vmCommentsList">
          <div class="vm-empty">
            <div class="vm-ei">💬</div>
            <span>Yükleniyor...</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ── CSRF Token ──
  const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

  // ── Custom Cursor ──
  const cur = document.getElementById('cur');
  document.addEventListener('mousemove', e => {
    cur.style.left = e.clientX + 'px';
    cur.style.top  = e.clientY + 'px';
  });
  function bindCursor() {
    document.querySelectorAll('a,button,input,textarea,select,label,.cmt-reply-btn').forEach(el => {
      el.removeEventListener('mouseenter', curGrow);
      el.removeEventListener('mouseleave', curShrink);
      el.addEventListener('mouseenter', curGrow);
      el.addEventListener('mouseleave', curShrink);
    });
  }
  function curGrow() { cur.classList.add('grow'); }
  function curShrink() { cur.classList.remove('grow'); }
  bindCursor();

  // ── Modal Helpers ──
  function openModal(id) {
    const el = document.getElementById(id);
    el.style.display = 'flex';
    setTimeout(() => el.classList.add('open'), 10);
  }
  function closeModal(id) {
    const el = document.getElementById(id);
    el.classList.remove('open');
    setTimeout(() => el.style.display = 'none', 260);
  }
  function closeOnOverlay(e, id) {
    if (e.target === document.getElementById(id)) closeModal(id);
  }

  // ── Edit Bolum Modal ──
  function openEditModal(bolumId, baslik, aciklama) {
    document.getElementById('editBolumId').value = bolumId;
    document.getElementById('editBaslik').value   = baslik;
    document.getElementById('editAciklama').value = aciklama;
    openModal('editModal');
  }

  // ── Bolum Sil ──
  function openBolumSilModal(bolumId, kursId) {
    document.getElementById('silBolumId').value = bolumId;
    openModal('bolumSilModal');
  }

  // ── Kurs Sil ──
  function showSilModal(e) {
    e.preventDefault();
    openModal('kursSilModal');
  }

  // ── VIDEO MODAL ──
  let currentBolumId = 0;

  function openVideoModal(bolumId, baslik, videoUrl, aciklama) {
    currentBolumId = bolumId;
    document.getElementById('vmTitle').textContent = baslik;
    document.getElementById('vmBadge').textContent = 'Bölüm #' + bolumId;
    document.getElementById('vmDesc').textContent = aciklama || 'Bu bölüm için açıklama eklenmemiş.';

    const player = document.getElementById('vmPlayer');
    player.src = videoUrl;
    player.load();

    openModal('videoModal');
    loadComments(bolumId);
  }

  function closeVideoModal() {
    const player = document.getElementById('vmPlayer');
    player.pause();
    player.src = '';
    closeModal('videoModal');
  }

  // ── LOAD COMMENTS ──
  async function loadComments(bolumId) {
    const container = document.getElementById('vmCommentsList');
    container.innerHTML = '<div class="vm-empty"><div class="vm-ei">⏳</div><span>Yorumlar yükleniyor...</span></div>';

    try {
      const resp = await fetch(`/Egitmen/BolumYorumlariniGetir?kursBolumuId=${bolumId}`);
      const yorumlar = await resp.json();

      document.getElementById('vmCommentCount').textContent = yorumlar.length;

      if (yorumlar.length === 0) {
        container.innerHTML = '<div class="vm-empty"><div class="vm-ei">💬</div><span style="font-size:.88rem;">Henüz yorum yapılmamış.</span><span style="font-size:.78rem;color:var(--muted);">Öğrenciler bu bölüme yorum yaptığında burada görünecek.</span></div>';
        return;
      }

      container.innerHTML = '';
      yorumlar.forEach(y => {
        container.appendChild(buildCommentCard(y));
      });

      bindCursor();
    } catch(err) {
      container.innerHTML = '<div class="vm-empty"><div class="vm-ei">⚠️</div><span>Yorumlar yüklenirken hata oluştu.</span></div>';
    }
  }

  // ── BUILD COMMENT CARD ──
  function buildCommentCard(yorum) {
    const card = document.createElement('div');
    card.className = 'cmt-card';

    const isEgitmen = (yorum.kullaniciRol || '').toLowerCase() === 'egitmen';
    const rolClass = isEgitmen ? 'egitmen' : 'ogrenci';
    const rolLabel = isEgitmen ? '🎓 Eğitmen' : '📚 Öğrenci';
    const initial = (yorum.kullaniciAdi || '?')[0].toUpperCase();

    let repliesHtml = '';
    if (yorum.yanitlar && yorum.yanitlar.length > 0) {
      const replyCards = yorum.yanitlar.map(r => {
        const rIsEgitmen = (r.kullaniciRol || '').toLowerCase() === 'egitmen';
        const rRolClass = rIsEgitmen ? 'egitmen' : 'ogrenci';
        const rRolLabel = rIsEgitmen ? '🎓 Eğitmen' : '📚 Öğrenci';
        const rInit = (r.kullaniciAdi || '?')[0].toUpperCase();
        return `
          <div class="cmt-reply-card">
            <div class="cmt-head">
              <div class="cmt-avatar ${rRolClass}">${rInit}</div>
              <span class="cmt-name">${escHtml(r.kullaniciAdi)}</span>
              <span class="cmt-role ${rRolClass}">${rRolLabel}</span>
              <span class="cmt-date">${escHtml(r.tarih)}</span>
            </div>
            <div class="cmt-text">${escHtml(r.yorum)}</div>
          </div>
        `;
      }).join('');
      repliesHtml = `<div class="cmt-replies">${replyCards}</div>`;
    }

    card.innerHTML = `
      <div class="cmt-head">
        <div class="cmt-avatar ${rolClass}">${initial}</div>
        <span class="cmt-name">${escHtml(yorum.kullaniciAdi)}</span>
        <span class="cmt-role ${rolClass}">${rolLabel}</span>
        <span class="cmt-date">${escHtml(yorum.tarih)}</span>
      </div>
      <div class="cmt-text">${escHtml(yorum.yorum)}</div>
      <button class="cmt-reply-btn" onclick="toggleReplyForm(this, ${yorum.id})">↩ Yanıtla</button>
      <div class="cmt-reply-form" id="replyForm-${yorum.id}">
        <textarea class="cmt-reply-input" placeholder="Yanıtınızı yazın..." id="replyInput-${yorum.id}"></textarea>
        <button class="cmt-reply-send" onclick="sendReply(${yorum.id})">Yanıt Gönder</button>
      </div>
      ${repliesHtml}
    `;
    return card;
  }

  function escHtml(str) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  // ── TOGGLE REPLY FORM ──
  function toggleReplyForm(btn, yorumId) {
    const form = document.getElementById('replyForm-' + yorumId);
    form.classList.toggle('open');
    if (form.classList.contains('open')) {
      document.getElementById('replyInput-' + yorumId).focus();
    }
  }

  // ── SEND REPLY ──
  async function sendReply(parentYorumId) {
    const input = document.getElementById('replyInput-' + parentYorumId);
    const yanit = input.value.trim();
    if (!yanit) { input.focus(); return; }

    const sendBtn = input.parentElement.querySelector('.cmt-reply-send');
    sendBtn.textContent = 'Gönderiliyor...';
    sendBtn.disabled = true;

    try {
      const formData = new FormData();
      formData.append('parentYorumId', parentYorumId);
      formData.append('yanit', yanit);
      formData.append('__RequestVerificationToken', csrfToken);

      const resp = await fetch('/Egitmen/BolumYorumYanitEkle', {
        method: 'POST',
        body: formData
      });
      const result = await resp.json();

      if (result.basarili) {
        input.value = '';
        loadComments(currentBolumId);
      } else {
        alert(result.mesaj || 'Yanıt gönderilemedi.');
      }
    } catch(err) {
      alert('Bir hata oluştu, tekrar deneyin.');
    } finally {
      sendBtn.textContent = 'Yanıt Gönder';
      sendBtn.disabled = false;
    }
  }

  // Smooth scroll for sidebar links
  document.querySelectorAll('.sidebar-nav a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const target = document.querySelector(a.getAttribute('href'));
      if (target) document.getElementById('mainScroll').scrollTo({ top: target.offsetTop - 40, behavior: 'smooth' });
    });
  });
</script>
</body>
</html>
