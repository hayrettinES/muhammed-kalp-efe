@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Öğretmen Kaydı — EduVerse</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
<script src="~/js/theme.js" asp-append-version="true"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #141c2e;
    --bg2:       #111827;
    --surface:   rgba(255,255,255,.05);
    --surfaceH:  rgba(255,255,255,.09);
    --glass:     rgba(20,28,46,.7);
    --border:    rgba(255,255,255,.09);
    --borderH:   rgba(255,255,255,.18);
    --copper:    #e8924a;
    --mint:      #3dffc0;
    --blue:      #7eb8ff;
    --lavender:  #b89cff;
    --text:      #e2e8f4;
    --text2:     #8898b8;
    --muted:     #4a5878;
    --fh:        'Cormorant Garamond', serif;
    --fs:        'Plus Jakarta Sans', sans-serif;
    --fm:        'JetBrains Mono', monospace;
    --r:         12px;
    --r2:        20px;
    --accent:    #3dffc0;
  }

  html, body { height: 100%; }

  body {
    font-family: var(--fs);
    background: var(--bg);
    color: var(--text);
    cursor: none;
    overflow-x: hidden;
  }

  /* Custom Cursor */
  .cursor {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--mint);
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: width .2s, height .2s, opacity .2s;
    mix-blend-mode: screen;
  }
  .cursor.grow { width: 28px; height: 28px; opacity: .7; }

  /* Neon Link */
  .neon-link {
    color: var(--mint) !important;
    text-shadow: 0 0 8px rgba(61,255,192,0.6);
    font-weight: bold;
    text-decoration: none;
    transition: all 0.2s;
  }
  .neon-link:hover {
    text-shadow: 0 0 15px rgba(61,255,192,0.9);
    opacity: 0.9;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg2); }
  ::-webkit-scrollbar-thumb { background: var(--copper); border-radius: 99px; }

  /* Layout */
  .page-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  /* ── LEFT PANEL ── */
  .left-panel {
    position: sticky;
    top: 0;
    height: 100vh;
    background: var(--bg2);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 3rem 3.5rem;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: .4;
    pointer-events: none;
  }
  .blob-1 { width: 440px; height: 440px; background: rgba(61,255,192,.15); top: -120px; left: -100px; }
  .blob-2 { width: 320px; height: 320px; background: rgba(232,146,74,.1);  bottom: 40px;  right: -60px; }
  .blob-3 { width: 180px; height: 180px; background: rgba(61,255,192,.08); top: 55%;     left: 45%; }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.07) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .left-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .logo-link {
    text-decoration: none;
    font-family: var(--fh);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--copper);
    letter-spacing: .02em;
    display: inline-block;
    margin-bottom: .4rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .8rem;
    color: var(--text2);
    text-decoration: none;
    margin-bottom: 2.8rem;
    transition: color .2s;
  }
  .back-link:hover { color: var(--text); }
  .back-link svg { width: 14px; height: 14px; }

  .role-tag {
    display: inline-block;
    font-family: var(--fm);
    font-size: .72rem;
    color: var(--mint);
    background: rgba(61,255,192,.08);
    border: 1px solid rgba(61,255,192,.2);
    border-radius: 100px;
    padding: .3rem .85rem;
    margin-bottom: 1.2rem;
    letter-spacing: .06em;
    text-transform: uppercase;
  }

  .display-title {
    font-family: var(--fh);
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.2rem;
  }
  .display-title em { font-style: italic; color: var(--mint); }

  .desc-text {
    font-size: .93rem;
    line-height: 1.7;
    color: var(--text2);
    max-width: 360px;
    margin-bottom: 1.8rem;
  }

  .perks-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .65rem;
    margin-bottom: 2rem;
  }
  .perks-list li {
    display: flex;
    align-items: center;
    gap: .7rem;
    font-size: .88rem;
    color: var(--text2);
  }
  .perk-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--mint);
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(61,255,192,.5);
  }

  /* Glass card */
  .glass-card {
    backdrop-filter: blur(16px);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.09);
    border-radius: var(--r2);
    padding: 1.4rem 1.6rem;
    margin-bottom: auto;
  }
  .glass-card-label {
    font-size: .75rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: .4rem;
    font-family: var(--fm);
  }
  .glass-card-value {
    font-family: var(--fh);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--mint);
    line-height: 1;
  }
  .glass-card-sub { font-size: .78rem; color: var(--text2); margin-top: .3rem; }

  .quote-block {
    margin-top: 1.8rem;
    padding: 1rem 1.2rem;
    border-left: 2px solid rgba(61,255,192,.35);
  }
  .quote-block p {
    font-family: var(--fh);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text2);
    line-height: 1.6;
  }

  /* ── RIGHT PANEL ── */
  .right-panel {
    background: var(--bg);
    overflow-y: auto;
    padding: 5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .right-panel::before {
    content: '';
    position: fixed;
    top: 0; left: 50%; right: 0; bottom: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  .form-container {
    width: 100%;
    max-width: 520px;
    position: relative;
    z-index: 1;
  }

  /* Step indicator */
  .step-indicator { margin-bottom: 2.8rem; }
  .step-progress-bar {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,.08);
    border-radius: 99px;
    margin-bottom: 1.2rem;
    overflow: hidden;
  }
  .step-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--mint), #1ec490);
    border-radius: 99px;
    transition: width .5s cubic-bezier(.4,0,.2,1);
    width: 33.3%;
  }
  .step-dots {
    display: flex;
    align-items: center;
    gap: .6rem;
  }
  .step-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,.15);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .75rem;
    font-weight: 600;
    color: var(--text2);
    font-family: var(--fm);
    transition: all .3s;
    flex-shrink: 0;
  }
  .step-dot.active { background: var(--mint); border-color: var(--mint); color: #0a1628; box-shadow: 0 0 12px rgba(61,255,192,.4); }
  .step-dot.done   { background: rgba(61,255,192,.15); border-color: rgba(61,255,192,.4); color: var(--mint); }
  .step-connector { flex: 1; height: 1px; background: rgba(255,255,255,.08); }
  .step-label { margin-top: .8rem; font-size: .8rem; color: var(--text2); font-family: var(--fm); }
  .step-label span { color: var(--mint); font-weight: 500; }

  /* Form head */
  .form-head { margin-bottom: 2rem; }
  .form-title { font-family: var(--fh); font-size: 2.1rem; font-weight: 700; color: var(--text); margin-bottom: .4rem; }
  .form-subtitle { font-size: .9rem; color: var(--text2); line-height: 1.6; }

  /* Form steps */
  .form-step { display: none; }
  .form-step.active { display: flex; flex-direction: column; gap: 1.1rem; }

  /* Fields */
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field-group { display: flex; flex-direction: column; gap: .45rem; }
  .field-label {
    font-size: .8rem;
    font-weight: 600;
    color: var(--text2);
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .field-opt { font-weight: 400; color: var(--muted); font-size: .72rem; margin-left: .3rem; text-transform: none; letter-spacing: 0; }
  .field-wrap { position: relative; }
  .field-wrap input,
  .field-wrap select,
  .field-wrap textarea {
    width: 100%;
    background: rgba(255,255,255,.06);
    border: 1px solid var(--border);
    border-radius: var(--r);
    color: var(--text);
    font-family: var(--fs);
    font-size: .92rem;
    padding: .85rem 1.1rem;
    outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s;
    appearance: none;
    -webkit-appearance: none;
  }
  .field-wrap input:focus,
  .field-wrap select:focus,
  .field-wrap textarea:focus {
    border-color: var(--mint);
    box-shadow: 0 0 0 3px rgba(61,255,192,.10);
    background: rgba(255,255,255,.08);
  }
  .field-wrap input::placeholder,
  .field-wrap textarea::placeholder { color: var(--muted); }
  .field-wrap select option { background: #1a2540; color: var(--text); }
  .field-icon { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--text2); font-size: 1rem; pointer-events: none; }
  .field-icon.clickable { pointer-events: all; cursor: pointer; user-select: none; }
  .field-wrap input.has-icon { padding-right: 2.8rem; }
  .select-wrap::after { content: '▾'; position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--text2); pointer-events: none; font-size: .85rem; }

  /* Textarea */
  .field-wrap textarea { resize: vertical; min-height: 90px; }

  /* Chips */
  .chips-grid { display: flex; flex-wrap: wrap; gap: .5rem; }
  .chip {
    display: inline-flex;
    align-items: center;
    padding: .45rem 1rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,.03);
    color: var(--text2);
    font-size: .82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
    user-select: none;
  }
  .chip:hover { border-color: var(--borderH); color: var(--text); background: rgba(255,255,255,.06); }
  .chip.active { border-color: var(--mint); background: rgba(61,255,192,.08); color: var(--mint); }

  /* Range slider */
  .slider-wrap { display: flex; flex-direction: column; gap: .6rem; }
  .slider-row { display: flex; align-items: center; gap: 1rem; }
  .slider-val {
    font-family: var(--fm);
    font-size: 1.1rem;
    color: var(--mint);
    min-width: 80px;
    text-align: right;
  }
  input[type="range"] {
    flex: 1;
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    border-radius: 99px;
    background: rgba(255,255,255,.12);
    outline: none;
    cursor: pointer;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--mint);
    border: 2px solid #0a1628;
    box-shadow: 0 0 8px rgba(61,255,192,.4);
    cursor: pointer;
  }
  input[type="range"]::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--mint);
    border: 2px solid #0a1628;
    cursor: pointer;
  }

  /* Format cards */
  .format-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
  }
  .format-card {
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 1rem 1.1rem;
    cursor: pointer;
    transition: all .25s;
    display: flex;
    flex-direction: column;
    gap: .35rem;
    user-select: none;
  }
  .format-card:hover { border-color: var(--borderH); background: rgba(255,255,255,.04); }
  .format-card.selected { border-color: var(--mint); background: rgba(61,255,192,.06); }
  .format-icon { font-size: 1.5rem; }
  .format-name { font-size: .88rem; font-weight: 600; color: var(--text); }
  .format-desc { font-size: .75rem; color: var(--text2); }

  /* Upload areas */
  .upload-area {
    border: 1.5px dashed rgba(255,255,255,.18);
    border-radius: var(--r);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .6rem;
    cursor: pointer;
    transition: all .2s;
    text-align: center;
  }
  .upload-area:hover { border-color: var(--mint); background: rgba(61,255,192,.04); }
  .upload-area input[type="file"] { display: none; }
  .upload-icon { font-size: 2rem; }
  .upload-title { font-size: .9rem; font-weight: 600; color: var(--text); }
  .upload-desc { font-size: .78rem; color: var(--text2); }
  .upload-btn-text {
    font-size: .8rem;
    color: var(--mint);
    font-weight: 600;
    margin-top: .2rem;
    text-decoration: underline;
    cursor: pointer;
  }

  /* Checkboxes */
  .check-group { display: flex; flex-direction: column; gap: .75rem; }
  .check-item { display: flex; align-items: flex-start; gap: .75rem; cursor: pointer; }
  .check-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    border: 1.5px solid var(--border);
    background: rgba(255,255,255,.06);
    accent-color: var(--mint);
    cursor: pointer;
    flex-shrink: 0;
    margin-top: .1rem;
  }
  .check-text { font-size: .84rem; color: var(--text2); line-height: 1.5; }
  .check-text a { color: var(--mint); text-decoration: none; }
  .check-text a:hover { text-decoration: underline; }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    border: none;
    cursor: pointer;
    font-family: var(--fs);
    font-weight: 700;
    font-size: .95rem;
    border-radius: 100px;
    padding: .95rem 2rem;
    transition: transform .2s, box-shadow .2s;
    text-decoration: none;
  }
  .btn:hover { transform: translateY(-2px); }
  .btn:active { transform: translateY(0); }
  .btn-primary {
    background: linear-gradient(135deg, #3dffc0, #1ec490);
    color: #0a1628;
    width: 100%;
    box-shadow: 0 4px 20px rgba(61,255,192,.2);
  }
  .btn-primary:hover { box-shadow: 0 8px 32px rgba(61,255,192,.35); }
  .btn-secondary {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    color: var(--text);
  }
  .btn-secondary:hover { background: rgba(255,255,255,.1); }
  .btn-row { display: flex; gap: .8rem; align-items: center; }
  .btn-row .btn-secondary { flex-shrink: 0; }
  .btn-row .btn-primary { flex: 1; }

  /* OR divider */
  .or-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.4rem 0;
    color: var(--muted);
    font-size: .8rem;
  }
  .or-divider::before,.or-divider::after { content:''; flex:1; height:1px; background:var(--border); }

  .btn-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    width: 100%;
    padding: .85rem 1.5rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,.04);
    color: var(--text);
    font-family: var(--fs);
    font-size: .9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all .2s;
  }
  .btn-social:hover { border-color: var(--borderH); background: rgba(255,255,255,.08); }
  .btn-social svg { width: 18px; height: 18px; flex-shrink: 0; }

  .role-switch {
    text-align: center;
    margin-top: 1.8rem;
    font-size: .85rem;
    color: var(--text2);
  }
  .role-switch a { color: var(--mint); text-decoration: none; font-weight: 600; }
  .role-switch a:hover { text-decoration: underline; }

  /* Section title */
  .section-title {
    font-size: .78rem;
    font-weight: 700;
    color: var(--text2);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: -.2rem;
    padding-top: .4rem;
    border-top: 1px solid var(--border);
  }

  @@media (max-width: 900px) {
    .left-panel { display: none; }
    .page-grid { grid-template-columns: 1fr; }
    .right-panel { padding: 3rem 1.5rem; }
    .right-panel::before { left: 0; }
    .format-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>

<div class="page-grid">

  <!-- ══ LEFT PANEL ══ -->
  <aside class="left-panel">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="dot-grid"></div>

    <div class="left-content">
      <a href="/" class="logo-link">EduVerse</a>
      <a href="/" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Ana sayfaya dön
      </a>

      <span class="role-tag">Öğretmen Kaydı</span>

      <h1 class="display-title">İlham ver,<br><em>kazan.</em></h1>

      <p class="desc-text">Uzmanlığınızı binlerce öğrenciye aktarın. EduVerse'in güçlü araçlarıyla kendi kurs markanızı oluşturun.</p>

      <ul class="perks-list">
        <li><span class="perk-dot"></span>%70 gelir payı, her ay düzenli ödeme</li>
        <li><span class="perk-dot"></span>Ücretsiz video, quiz ve sertifika araçları</li>
        <li><span class="perk-dot"></span>Canlı oturum Zoom entegrasyonu</li>
        <li><span class="perk-dot"></span>Detaylı öğrenci analitik paneli</li>
        <li><span class="perk-dot"></span>480+ öğretmen topluluğu &amp; mentorluk</li>
      </ul>

      <div class="glass-card">
        <div class="glass-card-label">Top 100 öğretmen ortalaması</div>
        <div class="glass-card-value">₺8.400<span style="font-size:1.2rem;font-weight:400;color:var(--text2)"> / ay</span></div>
        <div class="glass-card-sub">Kurs satışı + canlı ders gelirleri dahil</div>
      </div>

      <div class="quote-block">
        <p>"En iyi öğretmenler, öğrenmeye devam edenlerdir."</p>
      </div>
    </div>
  </aside>

  <!-- ══ RIGHT PANEL ══ -->
  <div style="position:fixed; top:1.2rem; right:1.5rem; z-index:100;">
    <div class="theme-toggle" title="Tema değiştir">
      <span class="theme-toggle-icon">🌙</span>
      <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
      <span class="theme-toggle-label">Koyu</span>
    </div>
  </div>
  <main class="right-panel">
    <div class="form-container">

      <!-- TempData mesajları -->
      @if (TempData["Hata"] != null)
      {
          <div style="background:rgba(220,60,60,.15);border:1px solid rgba(220,60,60,.35);border-radius:12px;padding:.9rem 1.2rem;margin-bottom:1.5rem;color:#ff8080;font-size:.88rem;">
              ⚠️ @TempData["Hata"]
          </div>
      }
      @if (TempData["Mesaj"] != null)
      {
          <div style="background:rgba(61,255,192,.1);border:1px solid rgba(61,255,192,.3);border-radius:12px;padding:.9rem 1.2rem;margin-bottom:1.5rem;color:#3dffc0;font-size:.88rem;">
              ✓ @TempData["Mesaj"]
          </div>
      }

      <!-- Step indicator -->
      <div class="step-indicator">
        <div class="step-progress-bar">
          <div class="step-progress-fill" id="progressFill"></div>
        </div>
        <div class="step-dots">
          <div class="step-dot active" id="dot1">1</div>
          <div class="step-connector"></div>
          <div class="step-dot" id="dot2">2</div>
          <div class="step-connector"></div>
          <div class="step-dot" id="dot3">3</div>
        </div>
        <div class="step-label" id="stepLabel">Adım 1 / 3 &nbsp;—&nbsp; <span>Kimlik Bilgileri</span></div>
      </div>

      <div class="form-head">
        <h2 class="form-title" id="formTitle">Kimlik Bilgileri</h2>
        <p class="form-subtitle" id="formSubtitle">Başvurunuzu oluşturmak için temel bilgilerinizi girin.</p>
      </div>

      <form id="regForm" method="post" action="/Hesap/Kayit" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="Rol" value="Egitmen" />

        <!-- ── STEP 1 ── -->
        <div class="form-step active" id="step1">

          <div class="field-row">
            <div class="field-group">
              <label class="field-label" for="firstName">Ad</label>
              <div class="field-wrap"><input type="text" id="firstName" name="__firstName" placeholder="Adınız" autocomplete="given-name" required /></div>
            </div>
            <div class="field-group">
              <label class="field-label" for="lastName">Soyad</label>
              <div class="field-wrap"><input type="text" id="lastName" name="__lastName" placeholder="Soyadınız" autocomplete="family-name" required /></div>
            </div>
          </div>
          <input type="hidden" id="AdSoyad" name="AdSoyad" value="" />

          <div class="field-group">
            <label class="field-label" for="email">E-posta</label>
            <div class="field-wrap">
              <input type="email" id="email" name="Eposta" placeholder="ornek@eposta.com" class="has-icon" autocomplete="email" required />
              <span class="field-icon">✉</span>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="password">Şifre</label>
            <div class="field-wrap">
              <input type="password" id="password" name="Sifre" placeholder="En az 8 karakter" class="has-icon" autocomplete="new-password" required />
              <span class="field-icon clickable" id="togglePw">👁</span>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="title">Unvan / Meslek</label>
            <div class="field-wrap">
              <input type="text" id="title" name="Unvan" placeholder="Örn: Senior Developer, UX Tasarımcısı…" />
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="linkedin">LinkedIn Profili <span class="field-opt">(isteğe bağlı)</span></label>
            <div class="field-wrap">
              <input type="url" id="linkedin" name="LinkedinProfili" placeholder="https://linkedin.com/in/kullanici" class="has-icon" />
              <span class="field-icon">🔗</span>
            </div>
          </div>

          <button type="button" class="btn btn-primary" id="next1Btn">Devam Et &nbsp;→</button>

          <div class="or-divider">ya da</div>

          <button type="button" class="btn-social" onclick="window.location.href='/Hesap/GoogleLogin?rol=Egitmen'">
            <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google ile devam et
          </button>

          <div class="role-switch">Öğrenci misiniz? <a href="/Hesap/KayitOgrenci">Öğrenci kaydı →</a></div>
        </div>

        <!-- ── STEP 2 ── -->
        <div class="form-step" id="step2">

          <div class="field-group">
            <label class="field-label">Uzmanlık Alanları</label>
            <div class="chips-grid" id="expertChips">
              <span class="chip" data-val="yazilim">Yazılım</span>
              <span class="chip" data-val="veri">Veri Bilimi</span>
              <span class="chip" data-val="ai">Yapay Zeka</span>
              <span class="chip" data-val="uiux">UI/UX Tasarım</span>
              <span class="chip" data-val="grafik">Grafik Tasarım</span>
              <span class="chip" data-val="pazarlama">Pazarlama</span>
              <span class="chip" data-val="is">İş Dünyası</span>
              <span class="chip" data-val="finans">Finans</span>
              <span class="chip" data-val="dil">Dil</span>
              <span class="chip" data-val="muzik">Müzik</span>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="expRange">Deneyim Yılı</label>
            <div class="slider-wrap">
              <div class="slider-row">
                <input type="range" id="expRange" min="0" max="30" value="5" step="1" />
                <span class="slider-val" id="sliderVal">5 yıl</span>
              </div>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label" for="bio">Biyografi</label>
            <div class="field-wrap">
              <textarea id="bio" name="Hakkinda" placeholder="Kendinizi ve uzmanlığınızı kısaca tanıtın…" style="min-height:110px;"></textarea>
            </div>
          </div>

          <div class="field-group">
            <label class="field-label">Kurs Formatı</label>
            <div class="format-grid" id="formatGrid">
              <div class="format-card" data-val="video">
                <span class="format-icon">🎥</span>
                <span class="format-name">Video Ders</span>
                <span class="format-desc">Önceden kaydedilmiş içerikler</span>
              </div>
              <div class="format-card" data-val="live">
                <span class="format-icon">📡</span>
                <span class="format-name">Canlı Ders</span>
                <span class="format-desc">Zoom entegrasyonlu oturumlar</span>
              </div>
              <div class="format-card" data-val="hybrid">
                <span class="format-icon">⚡</span>
                <span class="format-name">Hibrit</span>
                <span class="format-desc">Video + canlı kombinasyonu</span>
              </div>
              <div class="format-card" data-val="text">
                <span class="format-icon">📝</span>
                <span class="format-name">Metin &amp; Kaynak</span>
                <span class="format-desc">Makale, PDF ve egzersizler</span>
              </div>
            </div>
            <input type="hidden" id="KursFormatiHidden" name="KursFormati" value="" />
          </div>

          <div class="btn-row">
            <button type="button" class="btn btn-secondary" id="back1Btn">← Geri</button>
            <button type="button" class="btn btn-primary" id="next2Btn">Devam Et &nbsp;→</button>
          </div>

          <!-- Eğitmen profil alanlarını sunucuya taşıyan hidden inputlar -->
          <input type="hidden" id="UzmanlikAlanlariHidden" name="UzmanlikAlanlari" value="" />
          <input type="hidden" id="DeneyimYiliHidden" name="DeneyimYili" value="5" />
        </div>

        <!-- ── STEP 3 ── -->
        <div class="form-step" id="step3">

          <div class="field-group">
            <label class="field-label">Profil Fotoğrafı</label>
            <label class="upload-area" for="photoUpload">
              <input type="file" id="photoUpload" accept="image/*" />
              <span class="upload-icon">🖼</span>
              <span class="upload-title">Fotoğraf yükleyin</span>
              <span class="upload-desc">PNG veya JPG, max 5 MB</span>
              <span class="upload-btn-text">Dosya seçin veya sürükleyin</span>
            </label>
          </div>

          <div class="field-group">
            <label class="field-label">CV / Belge <span class="field-opt">(isteğe bağlı)</span></label>
            <label class="upload-area" for="cvUpload">
              <input type="file" id="cvUpload" accept=".pdf,.doc,.docx" />
              <span class="upload-icon">📄</span>
              <span class="upload-title">CV veya sertifika yükleyin</span>
              <span class="upload-desc">PDF, DOC — max 10 MB</span>
              <span class="upload-btn-text">Dosya seçin veya sürükleyin</span>
            </label>
          </div>

          <div class="field-group">
            <label class="field-label" for="pricing">Fiyatlandırma Seçimi</label>
            <div class="field-wrap select-wrap">
              <select id="pricing" name="FiyatlandirmaTercihi">
                <option value="" disabled selected>Tercih edilen model…</option>
                <option>Ücretli kurs (tek seferlik)</option>
                <option>Abonelik modeli</option>
                <option>Ücretsiz + premium içerik</option>
                <option>Kurumsal lisans</option>
              </select>
            </div>
          </div>

          <div class="check-group">
            <label class="check-item">
              <input type="checkbox" id="guidelines" required />
              <span class="check-text"><a href="#">İçerik Yönergelerini</a> okudum, EduVerse kalite standartlarına uyacağımı kabul ediyorum.</span>
            </label>
            <label class="check-item">
              <input type="checkbox" id="terms" required />
              <span class="check-text"><a href="#">Kullanım Koşulları</a> ve <a href="#">Gelir Paylaşım Sözleşmesi</a>'ni okudum, kabul ediyorum.</span>
            </label>
          </div>

          <div class="btn-row">
            <button type="button" class="btn btn-secondary" id="back2Btn">← Geri</button>
            <button type="submit" class="btn btn-primary" id="submitBtn">Başvuruyu Gönder 🏆</button>
          </div>
        </div>

      </form>
      
      <div class="role-switch" style="margin-top: 2rem; text-align: center;">
          Zaten hesabınız var mı? <a href="/Hesap/Giris" class="neon-link">O zaman giriş yapın →</a>
      </div>
    </div>
  </main>
</div>

<script>
  // ── Cursor ──
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top  = e.clientY + 'px';
  });
  document.querySelectorAll('a,button,.chip,.check-item,.format-card,.upload-area,.field-icon.clickable').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('grow'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('grow'));
  });

  // ── Steps ──
  const steps    = ['step1','step2','step3'];
  const titles   = ['Kimlik Bilgileri','Uzmanlık & Format','Belgeler & Onay'];
  const subs     = ['Başvurunuzu oluşturmak için temel bilgilerinizi girin.','Uzmanlık alanlarınızı ve kurs formatınızı belirleyin.','Son adım: belgelerinizi yükleyin ve koşulları onaylayın.'];
  const fills    = ['33.3%','66.6%','100%'];
  const dotIds   = ['dot1','dot2','dot3'];
  let current    = 0;

  function goTo(n) {
    document.getElementById(steps[current]).classList.remove('active');
    current = n;
    document.getElementById(steps[current]).classList.add('active');
    document.getElementById('progressFill').style.width = fills[current];
    document.getElementById('formTitle').textContent    = titles[current];
    document.getElementById('formSubtitle').textContent = subs[current];
    document.getElementById('stepLabel').innerHTML = `Adım ${current+1} / 3 &nbsp;—&nbsp; <span>${titles[current]}</span>`;
    dotIds.forEach((id, i) => {
      const d = document.getElementById(id);
      d.classList.remove('active','done');
      if (i < current) d.classList.add('done');
      else if (i === current) d.classList.add('active');
    });
    window.scrollTo({top:0, behavior:'smooth'});
  }

  document.getElementById('next1Btn').addEventListener('click', () => {
    const fn = document.getElementById('firstName').value.trim();
    const ln = document.getElementById('lastName').value.trim();
    const em = document.getElementById('email').value.trim();
    const pw = document.getElementById('password').value;
    if (!fn || !ln || !em || !pw) { alert('Lütfen zorunlu alanları doldurunuz.'); return; }
    if (pw.length < 8) { alert('Şifreniz en az 8 karakter olmak zorundadır!'); return; }
    // AdSoyad hidden alanını doldur
    document.getElementById('AdSoyad').value = fn + ' ' + ln;
    // Unvan henüz boş olabilir, step 2'de de doldurulabilir
    goTo(1);
  });
  document.getElementById('next2Btn').addEventListener('click', () => {
    // Uzmanlik chip degerleri hidden'a aktar
    const uzmanliklar = [...document.querySelectorAll('#expertChips .chip.active')]
      .map(c => c.dataset.val).filter(Boolean);
    document.getElementById('UzmanlikAlanlariHidden').value = uzmanliklar.join(',');
    // Deneyim yilini hidden'a aktar
    document.getElementById('DeneyimYiliHidden').value = document.getElementById('expRange').value;
    goTo(2);
  });
  document.getElementById('back1Btn').addEventListener('click', () => goTo(0));
  document.getElementById('back2Btn').addEventListener('click', () => goTo(1));

  // ── Form submit — son dogrulama ve hidden alanlari guncelle ──
  document.getElementById('regForm').addEventListener('submit', e => {
    const g = document.getElementById('guidelines').checked;
    const t = document.getElementById('terms').checked;
    if (!g || !t) {
      e.preventDefault();
      alert('Devam etmek için tüm zorunlu koşulları kabul etmelisiniz.');
      return;
    }
    const adSoyad = document.getElementById('AdSoyad').value.trim();
    if (!adSoyad) {
      e.preventDefault();
      alert('Lütfen 1. adıma dönüp Ad ve Soyad alanlarını doldurunuz.');
      return;
    }

    const seciliFormat = document.querySelector('#formatGrid .format-card.selected');
    if (!seciliFormat) {
      e.preventDefault();
      alert('Lütfen öğretim formatınızdan birini seçiniz.');
      return;
    }
    document.getElementById('KursFormatiHidden').value = seciliFormat.dataset.val;

    const fiyatSec = document.getElementById('pricing').value;
    if (!fiyatSec) {
      e.preventDefault();
      alert('Lütfen bir fiyatlandırma modeli seçiniz.');
      return;
    }

    // Son kez guncelle (kullanici step2 uzerindeyken submit yapmamis olabilir)
    const uzmanliklar = [...document.querySelectorAll('#expertChips .chip.active')]
      .map(c => c.dataset.val).filter(Boolean);
    if (uzmanliklar.length > 0) {
      document.getElementById('UzmanlikAlanlariHidden').value = uzmanliklar.join(',');
    } else {
      e.preventDefault();
      alert('Lütfen en az bir uzmanlık alanı seçiniz.');
      return;
    }
    document.getElementById('DeneyimYiliHidden').value = document.getElementById('expRange').value;
    // Formu sunucuya gonder (preventDefault YOK)
  });

  // ── Password toggle ──
  document.getElementById('togglePw').addEventListener('click', () => {
    const pw = document.getElementById('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  });

  // ── Range slider ──
  const slider = document.getElementById('expRange');
  const sliderVal = document.getElementById('sliderVal');
  slider.addEventListener('input', () => {
    const v = parseInt(slider.value);
    sliderVal.textContent = v === 0 ? '< 1 yıl' : v === 30 ? '30+ yıl' : `${v} yıl`;
    const pct = (v / 30) * 100;
    slider.style.background = `linear-gradient(90deg, #3dffc0 ${pct}%, rgba(255,255,255,.12) ${pct}%)`;
  });
  slider.style.background = 'linear-gradient(90deg, #3dffc0 16.6%, rgba(255,255,255,.12) 16.6%)';

  // ── Chips ──
  document.querySelectorAll('#expertChips .chip').forEach(c => c.addEventListener('click', () => c.classList.toggle('active')));

  // ── Format cards ──
  document.querySelectorAll('#formatGrid .format-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('#formatGrid .format-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    });
  });

  // ── File uploads ──
  ['photoUpload','cvUpload'].forEach(id => {
    document.getElementById(id).addEventListener('change', function() {
      if (this.files && this.files[0]) {
        const label = this.parentElement.querySelector('.upload-title');
        label.textContent = this.files[0].name;
      }
    });
  });
</script>
</body>
</html>

