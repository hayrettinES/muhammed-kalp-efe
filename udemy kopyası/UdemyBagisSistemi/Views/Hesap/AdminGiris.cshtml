@{
    Layout = null;
}
@model UdemyBagisSistemi.ViewModels.GirisViewModel

<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Yönetici Girişi — EduVerse</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{--bg:#0f1320;--bg2:#111827;--border:rgba(255,255,255,.09);--borderH:rgba(255,255,255,.18);--accent:#a78bfa;--accent2:rgba(167,139,250,.12);--text:#e2e8f4;--text2:#8898b8;--error:#ff4c4c;--fh:'Cormorant Garamond',serif;--fs:'Plus Jakarta Sans',sans-serif;--fm:'JetBrains Mono',monospace}
  html,body{height:100%}
  body{font-family:var(--fs);background:var(--bg);color:var(--text);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
  body::before{content:'';position:absolute;width:500px;height:500px;border-radius:50%;background:rgba(167,139,250,.08);filter:blur(120px);top:-100px;left:-100px;pointer-events:none}
  body::after{content:'';position:absolute;width:400px;height:400px;border-radius:50%;background:rgba(167,139,250,.06);filter:blur(100px);bottom:-80px;right:-80px;pointer-events:none}
  .card{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:24px;padding:3.5rem;max-width:440px;width:100%;position:relative;z-index:1;backdrop-filter:blur(10px)}
  .logo{font-family:var(--fh);font-size:1.6rem;color:var(--accent);font-weight:700;text-decoration:none;display:block;text-align:center;margin-bottom:2rem}
  .shield{text-align:center;font-size:3rem;margin-bottom:1rem}
  .title{font-family:var(--fh);font-size:2.2rem;font-weight:700;text-align:center;margin-bottom:.3rem}
  .subtitle{text-align:center;color:var(--text2);font-size:.9rem;margin-bottom:2.5rem}
  .field{margin-bottom:1.4rem}
  .field label{display:block;font-size:.78rem;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.5rem}
  .field input{width:100%;padding:1rem 1.2rem;background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:var(--fs);font-size:.95rem;transition:all .2s;outline:none}
  .field input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent2)}
  .btn{width:100%;padding:1.1rem;background:linear-gradient(135deg,#a78bfa,#7c5fd6);color:#fff;border:none;border-radius:100px;font-family:var(--fs);font-weight:700;font-size:1rem;cursor:pointer;transition:all .2s;margin-top:.5rem}
  .btn:hover{box-shadow:0 4px 20px rgba(167,139,250,.35);transform:translateY(-2px)}
  .alert-err{background:rgba(255,76,76,.1);border:1px solid rgba(255,76,76,.3);color:var(--error);padding:.8rem 1rem;border-radius:10px;margin-bottom:1.2rem;font-size:.88rem}
  .validation-summary-errors{background:rgba(255,76,76,.1);border:1px solid rgba(255,76,76,.3);color:var(--error);padding:.8rem 1rem;border-radius:10px;margin-bottom:1.2rem;font-size:.88rem}
  .validation-summary-errors ul{list-style:none;padding:0;margin:0}
  .back{display:block;text-align:center;margin-top:2rem;color:var(--text2);font-size:.85rem;text-decoration:none}
  .back:hover{color:var(--accent)}
</style>
</head>
<body>
<div class="card">
    <a href="/" class="logo">EduVerse</a>
    <div class="shield">🛡️</div>
    <h1 class="title">Yönetici Girişi</h1>
    <p class="subtitle">Bu alan yalnızca platform yöneticileri içindir.</p>

    @if (TempData["Hata"] is string hata)
    {
        <div class="alert-err">⚠️ @hata</div>
    }

    <form asp-action="AdminGiris" method="post" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <div class="field">
            <label>E-Posta Adresi</label>
            <input asp-for="Eposta" placeholder="admin@ornek.com" autocomplete="email" />
        </div>

        <div class="field">
            <label>Şifre</label>
            <input asp-for="Sifre" type="password" placeholder="••••••••" autocomplete="current-password" />
        </div>

        <button type="submit" class="btn">Yönetim Paneline Giriş →</button>
    </form>

    <a href="/" class="back">← Ana Sayfaya Dön</a>
</div>
</body>
</html>
