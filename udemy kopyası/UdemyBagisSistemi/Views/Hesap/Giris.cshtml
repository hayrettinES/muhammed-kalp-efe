@{
    Layout = null;
}
@model UdemyBagisSistemi.ViewModels.GirisViewModel

<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Giriş Yap — EduVerse</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
<script src="~/js/theme.js" asp-append-version="true"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #141c2e;
    --bg2:       #111827;
    --border:    rgba(255,255,255,.09);
    --borderH:   rgba(255,255,255,.18);
    --mint:      #3dffc0;
    --blue:      #7eb8ff;
    --copper:    #e8924a;
    --text:      #e2e8f4;
    --text2:     #8898b8;
    --error:     #ff4c4c;
    --fh:        'Cormorant Garamond', serif;
    --fs:        'Plus Jakarta Sans', sans-serif;
    --fm:        'JetBrains Mono', monospace;
    --r:         12px;
  }

  html, body { height: 100%; }

  body {
    font-family: var(--fs);
    background: var(--bg);
    color: var(--text);
    cursor: none;
    overflow-x: hidden;
  }

  /* Custom Cursor */
  .cursor {
    position: fixed;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--mint);
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: width .2s, height .2s, opacity .2s;
    mix-blend-mode: screen;
  }
  .cursor.grow { width: 28px; height: 28px; opacity: .7; }

  /* Page Layout */
  .page-grid {
    display: flex;
    flex-wrap: wrap;
    min-height: 100vh;
  }
  .page-grid > * { flex: 1; min-width: 320px; }

  /* ══ LEFT PANEL ══ */
  .left-panel {
    position: relative;
    background: var(--bg2);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 4rem;
  }

  /* Blobs */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: .4;
    pointer-events: none;
  }
  .blob-1 { width: 440px; height: 440px; background: rgba(61,255,192,.15); top: -100px; left: -100px; }
  .blob-2 { width: 320px; height: 320px; background: rgba(126,184,255,.15); bottom: -50px; right: -50px; }

  /* Dot grid */
  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.05) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .left-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .logo-link {
    text-decoration: none;
    font-family: var(--fh);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--mint);
    letter-spacing: .02em;
    display: inline-block;
    margin-bottom: 3rem;
  }

  .display-title {
    font-family: var(--fh);
    font-size: clamp(3.2rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.2rem;
  }
  .display-title em {
    font-style: italic;
    color: var(--mint);
  }

  .desc-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text2);
    max-width: 380px;
    margin-bottom: auto; /* pushes everything else down */
  }

  .glass-card {
    backdrop-filter: blur(16px);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.09);
    border-radius: 20px;
    padding: 1.4rem 1.6rem;
    margin-top: 3rem;
  }
  .glass-card-label {
    font-size: .75rem;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: .4rem;
    font-family: var(--fm);
  }
  .glass-card-value {
    font-family: var(--fh);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--mint);
    line-height: 1;
  }
  .glass-card-sub {
    font-size: .8rem;
    color: var(--text2);
    margin-top: .4rem;
  }

  /* ══ RIGHT PANEL ══ */
  .right-panel {
    background: var(--bg);
    padding: 5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .right-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  .form-container {
    width: 100%;
    max-width: 420px;
    position: relative;
    z-index: 1;
  }

  .form-head { margin-bottom: 2.5rem; }
  .form-title {
    font-family: var(--fh);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: .4rem;
  }
  .form-subtitle {
    font-size: .95rem;
    color: var(--text2);
  }

  /* Alerts */
  .alert {
    padding: 1rem 1.2rem;
    border-radius: var(--r);
    margin-bottom: 1.5rem;
    font-size: .9rem;
  }
  .alert-success {
    background: rgba(61,255,192,.1);
    border: 1px solid rgba(61,255,192,.3);
    color: var(--mint);
  }
  .alert-error {
    background: rgba(255,76,76,.1);
    border: 1px solid rgba(255,76,76,.3);
    color: var(--error);
  }
  .validation-summary-errors {
    color: var(--error);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.2rem;
    background: rgba(255,76,76,.1);
    border-radius: var(--r);
    border: 1px solid rgba(255,76,76,.3);
  }
  .validation-summary-errors ul { list-style: none; padding: 0; margin: 0; }

  /* Inputs */
  .field-group { margin-bottom: 1.4rem; display: flex; flex-direction: column; }
  .field-label {
    font-size: .8rem;
    font-weight: 600;
    color: var(--text2);
    letter-spacing: .04em;
    text-transform: uppercase;
    margin-bottom: .6rem;
  }
  .field-input {
    width: 100%;
    background: rgba(255,255,255,.06);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 1rem 1.2rem;
    color: var(--text);
    font-family: var(--fs);
    font-size: .95rem;
    transition: all .2s;
    outline: none;
  }
  .field-input:focus {
    border-color: var(--mint);
    background: rgba(255,255,255,.08);
    box-shadow: 0 0 0 3px rgba(61,255,192,.12);
  }
  .validation-error { color: var(--error); font-size: 0.8rem; margin-top: 0.4rem; font-weight: 500; }

  /* Buttons */
  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    width: 100%;
    background: linear-gradient(135deg, #3dffc0, #1ec490);
    color: #0a1628;
    padding: 1.1rem;
    border-radius: 100px;
    border: none;
    font-family: var(--fs);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: transform .2s, box-shadow .2s;
    margin-top: 1rem;
  }
  .btn-submit:hover {
    box-shadow: 0 4px 20px rgba(61,255,192,.3);
    transform: translateY(-2px);
  }
  .btn-submit:active { transform: translateY(0); }

  .or-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.6rem 0;
    color: var(--muted);
    font-size: .85rem;
  }
  .or-divider::before,.or-divider::after { content:''; flex:1; height:1px; background:var(--border); }

  .btn-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    width: 100%;
    padding: 1rem 1.5rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,.04);
    color: var(--text);
    font-family: var(--fs);
    font-size: .95rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all .2s;
  }
  .btn-social:hover {
    border-color: var(--borderH);
    background: rgba(255,255,255,.08);
  }
  .btn-social svg { width: 20px; height: 20px; flex-shrink: 0; }

  /* Register links */
  .register-link {
    text-align: center;
    margin-top: 2.5rem;
    font-size: .9rem;
    color: var(--text2);
    line-height: 1.6;
  }
  .register-link a {
    color: var(--mint);
    text-decoration: none;
    font-weight: 600;
  }
  .register-link a:hover {
    text-decoration: underline;
  }

  @@media (max-width: 900px) {
    .left-panel { display: none; }
    .right-panel { padding: 4rem 2rem; }
  }
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>

<div class="page-grid">

  <!-- ══ LEFT PANEL ══ -->
  <aside class="left-panel">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="dot-grid"></div>

    <div class="left-content">
      <a href="/" class="logo-link">EduVerse</a>

      <h1 class="display-title">Tekrar<br><em>hoş geldin.</em></h1>
      <p class="desc-text">Kaldığın yerden devam et. Öğrendiklerinle dünyanı değiştirmek için tam zamanı.</p>

      <div class="glass-card">
        <div class="glass-card-label">BİLGİ PaylaştIkça Büyür</div>
        <div class="glass-card-value">EduVerse</div>
        <div class="glass-card-sub">Senin için özel tasarlandı</div>
      </div>
    </div>
  </aside>

  <!-- ══ RIGHT PANEL ══ -->
  <div style="position:fixed; top:1.2rem; right:1.5rem; z-index:100;">
    <div class="theme-toggle" title="Tema değiştir">
      <span class="theme-toggle-icon">🌙</span>
      <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
      <span class="theme-toggle-label">Koyu</span>
    </div>
  </div>
  <main class="right-panel">
    <div class="form-container">
      
      <div class="form-head">
        <h2 class="form-title">Giriş Yap</h2>
        <p class="form-subtitle">EduVerse hesabınıza giriş yapın.</p>
      </div>

      @if (TempData["Mesaj"] is string mesaj)
      {
          <div class="alert alert-success">✓ @mesaj</div>
      }
      @if (TempData["Hata"] is string hata)
      {
          <div class="alert alert-error">⚠️ @hata</div>
      }

      <form asp-action="Giris" method="post" novalidate>
          @Html.AntiForgeryToken()

          <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

          <div class="field-group">
              <label class="field-label">E-Posta Adresi</label>
              <input asp-for="Eposta" class="field-input" placeholder="mailiniz@ornek.com" autocomplete="email" />
              <span asp-validation-for="Eposta" class="validation-error"></span>
          </div>

          <div class="field-group">
              <label class="field-label">Şifre</label>
              <input asp-for="Sifre" type="password" class="field-input" placeholder="••••••••" autocomplete="current-password" />
              <span asp-validation-for="Sifre" class="validation-error"></span>
          </div>

          <button type="submit" class="btn-submit">Hesaba Giriş Yap →</button>
      </form>

      <div class="or-divider">ya da güvenli giriş yap</div>

      <a href="/Hesap/GoogleLogin" class="btn-social">
        <svg viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Google ile devam et
      </a>

      <div class="register-link">
          Hesabınız yok mu?<br>
          <a href="/Hesap/KayitOgrenci">Öğrenci Kaydı</a> • <a href="/Hesap/KayitEgitmen">Eğitmen Kaydı</a>
      </div>
    </div>
  </main>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
<script>
  // Cursor
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top  = e.clientY + 'px';
  });
  document.querySelectorAll('a, button, input').forEach(el => {
    el.addEventListener('mouseenter', () => cursor.classList.add('grow'));
    el.addEventListener('mouseleave', () => cursor.classList.remove('grow'));
  });
</script>
</body>
</html>
