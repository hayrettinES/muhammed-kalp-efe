@{
    Layout = null;
    var profilUrl = string.IsNullOrWhiteSpace(Model.Profil.ProfilFotoUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.Profil.AdSoyad) + "&background=random" : Model.Profil.ProfilFotoUrl;
    var alinmayanKurslar = Model.Kurslar.Where(k => !Model.AldigiKurslar.Any(a => a.Kurs.Id == k.Kurs.Id)).ToList();
    var tamamlananKurs = Model.Ilerlemeler.Count(x => x.TamamlanmaYuzdesi >= 100);
}
@model UdemyBagisSistemi.ViewModels.OgrenciPanelViewModel

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Öğrenci Paneli — EduVerse</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/assistant.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        
        :root {
            --bg: #141c2e;
            --bg2: #111827;
            --surface: rgba(255,255,255,.05);
            --surfaceH: rgba(255,255,255,.09);
            --glass: rgba(20,28,46,.7);
            --border: rgba(255,255,255,.09);
            --borderH: rgba(255,255,255,.18);
            --copper: #e8924a;
            --mint: #3dffc0;
            --text: #e2e8f4;
            --text2: #8898b8;
            --fh: 'Cormorant Garamond', serif;
            --fs: 'Plus Jakarta Sans', sans-serif;
            --fm: 'JetBrains Mono', monospace;
        }

        body {
            font-family: var(--fs);
            background: var(--bg);
            color: var(--text);
            display: flex;
            min-height: 100vh;
            cursor: none;
        }

        /* ══ CUSTOM CURSOR ══ */
        .cursor {
            position: fixed;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: var(--copper);
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%,-50%);
            transition: width .2s, height .2s, opacity .2s;
            mix-blend-mode: screen;
        }
        .cursor.grow { width: 28px; height: 28px; opacity: .7; }

        /* ══ CUSTOM SCROLLBAR ══ */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--copper); }

        .sidebar {
            width: 280px;
            background: var(--bg2);
            border-right: 1px solid var(--border);
            padding: 2.5rem 2rem;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, margin-left 0.3s ease;
        }
        .sidebar.collapsed {
            transform: translateX(-100%);
            margin-left: -280px;
        }

        .logo {
            font-family: var(--fh);
            font-size: 2.2rem;
            color: var(--copper);
            text-decoration: none;
            font-weight: bold;
            margin-bottom: 3rem;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-left: 2.5rem; /* Buton için boşluk */
        }

        .logo span { font-size: 1rem; font-family: var(--fs); color: var(--text2); letter-spacing: 2px; }

        .nav-menu {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        .nav-item {
            color: var(--text2);
            text-decoration: none;
            padding: 1rem 1.2rem;
            border-radius: 12px;
            transition: all .3s ease;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item:hover {
            background: var(--surfaceH);
            color: var(--text);
        }

        .nav-item.active {
            background: rgba(232, 146, 74, 0.1);
            color: var(--copper);
            border: 1px solid rgba(232, 146, 74, 0.2);
        }

        .user-widget {
            margin-top: auto;
            border-top: 1px solid var(--border);
            padding-top: 2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .user-img {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--copper);
        }

        .user-info h4 { font-size: 0.95rem; color: var(--text); }
        .user-info p { font-size: 0.8rem; color: var(--text2); font-family: var(--fm); }

        .main-content {
            flex: 1;
            padding: 3rem 4rem;
            position: relative;
            overflow-y: auto;
            height: 100vh;
        }

        .st-pane { display: none; animation: fadeIn 0.4s ease forwards; }
        .st-pane.active { display: block; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .header { margin-bottom: 3rem; }
        .header h1 { font-family: var(--fh); font-size: 3rem; color: var(--copper); line-height: 1.1; }
        .header p { color: var(--text2); margin-top: 1rem; font-size: 1.1rem; max-width: 600px; line-height: 1.6; }

        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 3rem; }
        .grid-4 { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;}

        /* STAT CARDS */
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 2rem;
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            transition: all .3s;
        }
        .stat-card:hover { transform: translateY(-5px); border-color: rgba(232, 146, 74, 0.4); background: var(--surfaceH); }
        .stat-card span { display: block; color: var(--text2); font-size: 1rem;font-weight: 500; margin-bottom: 1rem; z-index: 1;}
        .stat-card strong { font-family: var(--fm); font-size: 2.2rem; color: var(--text); z-index: 1;}
        
        .stat-card.copper { background: linear-gradient(135deg, rgba(232,146,74,.1) 0%, rgba(20,28,46,0) 100%); border-color: rgba(232,146,74,.3);}
        .stat-card.mint { background: linear-gradient(135deg, rgba(61,255,192,.1) 0%, rgba(20,28,46,0) 100%); border-color: rgba(61,255,192,.3);}

        /* ACTIONS */
        .actions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 3rem;}
        .action-box {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 2rem;
            border-radius: 20px;
        }
        .action-box h3 { font-size: 1.4rem; font-family: var(--fh); color: var(--text); margin-bottom: 0.5rem;}
        .action-box p { color: var(--text2); font-size: 0.95rem; margin-bottom: 1.5rem;}

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            background: var(--copper);
            color: var(--bg2);
            text-decoration: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 1rem;
            border: none;
            transition: all .3s;
        }
        .btn:hover { transform: scale(1.02); filter: brightness(1.1); box-shadow: 0 4px 15px rgba(232,146,74,.3); }
        .btn.outline { background: transparent; border: 1px solid var(--border); color: var(--text); }
        .btn.outline:hover { background: var(--surface); box-shadow: none;}
        .btn.mint { background: var(--mint); color: var(--bg2); }

        /* COURSE CARDS */
        .course-card {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
            will-change: transform;
        }
        .course-card:hover { transform: translateY(-5px); border-color: rgba(232, 146, 74, 0.4); box-shadow: 0 10px 30px rgba(0,0,0,.3); }
        .course-thumb {
            height: 160px;
            background: #1a233a;
            position: relative;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        .course-thumb img { width: 100%; height: 100%; object-fit: cover;}
        .course-badge {
            position: absolute; top: 10px; right: 10px;
            background: rgba(0,0,0,.6); color: var(--mint);
            padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-family: var(--fm); font-weight: bold; backdrop-filter: blur(5px);
        }
        .course-body { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
        .course-body h3 { font-size: 1.1rem; color: var(--text); margin-bottom: 0.5rem; line-height: 1.4;}
        .course-body p { color: var(--text2); font-size: 0.9rem; margin-bottom: 1.5rem; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

        .progress-container { margin-bottom: 1.5rem; }
        .progress-header { display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text2); margin-bottom: 5px; font-family: var(--fm);}
        .progress-bar { width: 100%; height: 6px; background: rgba(255,255,255,.1); border-radius: 3px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--copper); border-radius: 3px; transition: width 1s ease; }

        /* FORM */
        .form-group { margin-bottom: 1.5rem;}
        .form-group label { display: block; margin-bottom: 0.5rem; color: var(--text2); font-size: 0.9rem;}
        .form-control { width: 100%; padding: 12px 16px; background: rgba(255,255,255,.01); border: 1px solid var(--border); color: var(--text); border-radius: 10px; font-family: var(--fs); font-size: 1rem; transition: all .3s ease; backdrop-filter: blur(5px); }
        .form-control:focus { outline: none; border-color: var(--copper); background: rgba(255,255,255,.03); box-shadow: 0 0 15px rgba(232,146,74,.1); }
        .alert-box { background: rgba(61,255,192,.1); border: 1px solid rgba(61,255,192,.3); padding: 1rem 1.5rem; border-radius: 12px; color: var(--mint); margin-bottom: 2rem; display: flex; align-items: center; gap: 10px; }
        .alert-box.error { background: rgba(255,90,90,.1); border-color: rgba(255,90,90,.3); color: #ff5a5a; }

    </style>
</head>
<body>
    <div class="cursor" id="cursor"></div>

    <button id="sidebarToggle" style="position:fixed; top: 2.8rem; left: 1.5rem; z-index: 1001; background:transparent; border:none; color:var(--text); transition: all .3s;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <a href="/" class="logo">EduVerse</a>
        <ul class="nav-menu">
            <li><a class="nav-item active" data-tab="tab-dashboard">Dashboard</a></li>
            <li><a class="nav-item" data-tab="tab-kurslarim">Eğitimlerim</a></li>
            <li><a class="nav-item" data-tab="tab-magaza">Kurs Mağazası</a></li>
            <li><a class="nav-item" data-tab="tab-profil">Profil Ayarları</a></li>
            <li style="margin-top:auto;">
                <div class="theme-toggle" title="Tema değiştir" style="padding:0.5rem 1rem;">
                    <span class="theme-toggle-icon">🌙</span>
                    <div class="theme-toggle-track"><div class="theme-toggle-thumb"></div></div>
                    <span class="theme-toggle-label">Koyu</span>
                </div>
            </li>
            <li style="margin-top:10px;"><a href="/Hesap/Cikis" class="nav-item btn outline" style="justify-content:center;">Çıkış Yap</a></li>
        </ul>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        
        @if (TempData["Mesaj"] != null)
        {
            <div class="alert-box">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                @TempData["Mesaj"]
            </div>
        }
        @if (TempData["Hata"] != null)
        {
            <div class="alert-box error">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                @TempData["Hata"]
            </div>
        }

        <!-- TAB: DASHBOARD -->
        <div id="tab-dashboard" class="st-pane active">
            <header class="header">
                <h1>Öğrenme Serüveninize<br>Hoş Geldiniz!</h1>
                <p>Yeni yetenekler keşfedin, eğitimlerinizi takip edin ve geleceğinize harika yatırımlar yapın.</p>
            </header>

            <div class="grid-3">
                <div class="stat-card">
                    <span>Tamamlanan Eğitim</span>
                    <strong>@tamamlananKurs</strong>
                </div>
                <div class="stat-card copper">
                    <span>Kendi Bakiyeniz</span>
                    <strong>@Model.OgrenciBakiyesi.ToString("N2") ₺</strong>
                </div>
                <div class="stat-card mint">
                    <span>Ortak Bağış Havuzu</span>
                    <strong>@Model.HavuzBakiyesi.ToString("N2") ₺</strong>
                </div>
            </div>

            <div class="actions-grid">
                <div class="action-box">
                    <h3 style="color: var(--copper);">Cüzdanınıza Yükleme Yapın</h3>
                    <p>Kendinize ait cüzdanınızdaki bakiyeyle anında onaylı kurs alışverişi yapabilirsiniz. İstediğiniz tutarı yükleyin.</p>
                    <form asp-action="BakiyeYukle" method="post" style="display:flex; gap:10px;">
                        <input type="number" name="tutar" class="form-control" placeholder="Miktar (Örn: 100)" required style="max-width: 150px;">
                        <button type="submit" class="btn">Bakiye Yükle</button>
                    </form>
                </div>
                <div class="action-box" style="border-color: rgba(61,255,192,.3)">
                    <h3 style="color: var(--mint);">Havuzu Destekleyin</h3>
                    <p>Bağış havuzuna katkıda bulunarak, imkanı olmayan diğer öğrencilerin de ücretsiz eğitim almasına vesile olun.</p>
                    <form asp-action="BagisYap" method="post" style="display:flex; gap:10px;">
                        <input type="hidden" name="bagisciAdSoyad" value="@Model.Profil.AdSoyad" />
                        <input type="number" name="tutar" class="form-control" placeholder="Miktar (Örn: 50)" required style="max-width: 150px;">
                        <button type="submit" class="btn mint">Bağış Yap</button>
                    </form>
                </div>
            </div>

            <div style="margin-top: 3rem;">
                <h3 style="font-family: var(--fh); font-size: 2rem; margin-bottom: 2rem;">Son İzlenen Eğitimler</h3>
                @if (Model.AldigiKurslar.Any())
                {
                    <div class="grid-4">
                        @foreach (var kurs in Model.AldigiKurslar.Take(3))
                        {
                            var ilerleme = Model.Ilerlemeler.FirstOrDefault(x => x.KursId == kurs.Kurs.Id);
                            <div class="course-card">
                                <div class="course-thumb">
                                    <img src="@kurs.Kurs.OnizlemeVideoUrl" alt="Kurs" onerror="this.src='https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=400&q=80'" />
                                    <span class="course-badge">Eğitim</span>
                                </div>
                                <div class="course-body">
                                    <h3>@kurs.Kurs.Baslik</h3>
                                    <div class="progress-container" style="margin-top: auto; margin-bottom:1rem;">
                                        <div class="progress-header">
                                            <span>İlerleme</span>
                                            <span>%(ilerleme?.TamamlanmaYuzdesi ?? 0)</span>
                                        </div>
                                        <div class="progress-bar">
                                            <div class="progress-fill" style="width: @(ilerleme?.TamamlanmaYuzdesi ?? 0)%"></div>
                                        </div>
                                    </div>
                                    <a href="/Ogrenci/KursDetay?kursId=@kurs.Kurs.Id" class="btn outline" style="width:100%">Eğitimi Sürdür</a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 3rem; text-align: center; background: var(--surface); border-radius: 16px; border: 1px dashed var(--border);">
                         <p style="color: var(--text2);">Henüz hiç kurs almadınız. Mağazaya giderek yeni şeyler öğrenebilirsiniz.</p>
                         <br>
                         <button class="btn" onclick="document.querySelector('[data-tab=\'tab-magaza\']').click()">Kurs Mağazası</button>
                    </div>
                }
            </div>
        </div>

        <!-- TAB: EĞİTİMLERİM -->
        <div id="tab-kurslarim" class="st-pane">
            <header class="header">
                <h1>Eğitim Kütüphaneniz</h1>
                <p>Sahip olduğunuz tüm kurslar burada. Bir kursa tıklayarak derslere başlayabilir kalıp yorum yapabilirsiniz.</p>
            </header>

            <div class="grid-4">
                @foreach (var kurs in Model.AldigiKurslar)
                {
                     var ilerleme = Model.Ilerlemeler.FirstOrDefault(x => x.KursId == kurs.Kurs.Id);
                     <div class="course-card">
                        <div class="course-thumb">
                            <img src="@kurs.Kurs.OnizlemeVideoUrl" alt="Kurs" onerror="this.src='https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=400&q=80'" />
                        </div>
                        <div class="course-body">
                            <h3>@kurs.Kurs.Baslik</h3>
                            <p>@kurs.KategoriAdi</p>
                            <div class="progress-container" style="margin-top: auto; margin-bottom:1.5rem;">
                                <div class="progress-header">
                                    <span>Durum</span>
                                    <span>%(ilerleme?.TamamlanmaYuzdesi ?? 0)</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: @(ilerleme?.TamamlanmaYuzdesi ?? 0)%"></div>
                                </div>
                            </div>
                            <a href="/Ogrenci/KursDetay?kursId=@kurs.Kurs.Id" class="btn" style="width:100%">Derse Git</a>
                        </div>
                    </div>
                }
            </div>
            
            @if(!Model.AldigiKurslar.Any()) {
                <div style="padding: 4rem; text-align: center; border: 1px dashed var(--borderH); border-radius: 16px;">Kütüphaneniz şu an boş.</div>
            }
        </div>

        <!-- TAB: MAĞAZA -->
        <div id="tab-magaza" class="st-pane">
            <header class="header">
                <h1>Kurs &amp; Eğitim Mağazası</h1>
                <p>Yetkinliklerinizi artıracak en seçkin eğitimleri bularak cüzdanınızla veya havuz desteğiyle satın alın.</p>
            </header>

             <div class="grid-4">
                @foreach (var kurs in alinmayanKurslar)
                {
                     <div class="course-card">
                        <div class="course-thumb">
                            <img src="@kurs.Kurs.OnizlemeVideoUrl" alt="Kurs" onerror="this.src='https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=400&q=80'" />
                            <span class="course-badge" style="background:var(--copper); color:#111">@kurs.Kurs.Fiyat.ToString("N2") ₺</span>
                        </div>
                        <div class="course-body">
                            <h3>@kurs.Kurs.Baslik</h3>
                            <p>Eğitmen: @kurs.EgitmenAdi / Kategori: @kurs.KategoriAdi</p>
                            
                            <form asp-action="KursAl" method="post" style="margin-top:auto;" onsubmit="return confirm('Bu kurs hesaptaki/havuzdaki bakiye kullanılarak satın alınacaktır. Onaylıyor musunuz?');">
                                <input type="hidden" name="kursId" value="@kurs.Kurs.Id" />
                                <button type="submit" class="btn outline" style="width:100%; border-color:var(--copper); color:var(--copper);">Hemen Satın Al</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
            @if(!alinmayanKurslar.Any()) {
                <div style="padding: 4rem; text-align: center; border: 1px dashed var(--borderH); border-radius: 16px;">Şu anda mağazada satın alabileceğiniz yeni bir kurs bulunmuyor.</div>
            }
        </div>

        <!-- TAB: PROFIL AYARLARI -->
        <div id="tab-profil" class="st-pane">
            <header class="header">
                <h1>Kişisel Bilgileriniz</h1>
                <p>Profilinizi güncelleyerek özelleştirilmiş eğitim önerileri alabilir ve deneyiminizi geliştirebilirsiniz.</p>
            </header>

            <div style="background: var(--surface); padding: 3rem; border-radius: 20px; border: 1px solid var(--border); max-width: 800px;">
                <form asp-action="ProfilGuncelle" asp-controller="Ogrenci" method="post" enctype="multipart/form-data">
                     <input type="hidden" name="mevcutFotoUrl" value="@Model.Profil.ProfilFotoUrl" />
                     
                     <div class="form-group" style="display: flex; align-items: center; gap: 20px; margin-bottom: 2.5rem;">
                         <img id="previewImage" src="@profilUrl" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--copper);" />
                         <div>
                             <label style="color:var(--text); font-weight:bold; margin-bottom:10px;">Profil Fotoğrafı</label>
                             <input type="file" name="profilFoto" id="profilFotoInput" accept="image/*" class="form-control" style="padding: 8px;">
                         </div>
                     </div>

                     <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
                        <div class="form-group">
                            <label>Adınız ve Soyadınız</label>
                            <input type="text" name="adSoyad" class="form-control" value="@Model.Profil.AdSoyad" required />
                        </div>
                        <div class="form-group">
                            <label>E-posta Adresi</label>
                            <input type="email" name="eposta" class="form-control" value="@Model.Profil.Eposta" required />
                        </div>
                     </div>

                     <div class="form-group">
                         <label>Eğitim Seviyeniz</label>
                         <select name="egitimSeviyesi" class="form-control" required style="background: var(--bg2);">
                            <!option value="Lise" @(Model.Profil.EgitimSeviyesi == "Lise" ? "selected" : null)>Lise</!option>
                            <!option value="Ön Lisans" @(Model.Profil.EgitimSeviyesi == "Ön Lisans" ? "selected" : null)>Ön Lisans</!option>
                            <!option value="Lisans" @(Model.Profil.EgitimSeviyesi == "Lisans" ? "selected" : null)>Lisans</!option>
                            <!option value="Yüksek Lisans/Doktora" @(Model.Profil.EgitimSeviyesi == "Yüksek Lisans/Doktora" ? "selected" : null)>Yüksek Lisans / Doktora</!option>
                            <!option value="Mezun" @(Model.Profil.EgitimSeviyesi == "Mezun" ? "selected" : null)>Mezun / Çalışan</!option>
                         </select>
                     </div>

                     <div class="form-group">
                         <label>Kariyer/Eğitim Hedefi</label>
                         <input type="text" name="hedef" class="form-control" value="@Model.Profil.Hedef" placeholder="Örn: Yazılım Geliştirici Olmak" />
                     </div>

                     <div class="form-group">
                         <label>İlgi Alanlarınız (Virgülle ayırın)</label>
                         <textarea name="ilgiAlanlari" class="form-control" rows="3">@Model.Profil.IlgiAlanlari</textarea>
                     </div>

                     <div style="text-align: right; margin-top: 2rem;">
                         <button type="submit" class="btn">Değişiklikleri Kaydet</button>
                     </div>
                </form>
            </div>
        </div>

    </main>

    <!-- AI ASISTAN WIDGET -->
    @await Html.PartialAsync("_AssistantWidget")

    <script>
        // SPA TAB LOGIC
        const tabs = document.querySelectorAll('.nav-item[data-tab]');
        const panes = document.querySelectorAll('.st-pane');

        tabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                const target = tab.dataset.tab;
                
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                
                panes.forEach(p => p.classList.remove('active'));
                document.getElementById(target).classList.add('active');
            });
        });

        // PREVIEW IMAGE LOGIC
        const uploadInput = document.getElementById('profilFotoInput');
        const preview = document.getElementById('previewImage');
        if (uploadInput) {
            uploadInput.addEventListener('change', function(e) {
                if(this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(ex) { preview.src = ex.target.result; }
                    reader.readAsDataURL(this.files[0]);
                }
            });
        }

        // ── Cursor ──
        const cursor = document.getElementById('cursor');
        document.addEventListener('mousemove', e => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top  = e.clientY + 'px';
        });
        document.querySelectorAll('a, button, input, select, textarea, .nav-item').forEach(el => {
            el.addEventListener('mouseenter', () => cursor.classList.add('grow'));
            el.addEventListener('mouseleave', () => cursor.classList.remove('grow'));
        });

        // SIDEBAR TOGGLE
        document.getElementById('sidebarToggle').addEventListener('click', () => {
            document.querySelector('.sidebar').classList.toggle('collapsed');
        });

    </script>
    <script src="~/js/assistant.js" asp-append-version="true"></script>
</body>
</html>
